@*<h3>AddBlog</h3>*@
@inject IStringLocalizer<Resource> _localizer
@page "/AddBlog"
<MudOverlay Visible="isVisible" LightBackground=true ZIndex="9999">
    <MudText Align="Align.Center">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </MudText>
</MudOverlay>
<style>
    .jst{
        display:flex;
        justify-content:center;
        background: #f5f5f5;
        height: 100vh;
    }
</style>
<div class="jst">
    <MudPaper Width="60%" Class="d-flex flex-column overflow-scroll my-4" Height="95vh">
        <MudGrid Justify="Justify.Center" Class="pa-5" Spacing="1">
            @*<MudItem sm="11" xs="11" md="11">

            </MudItem>*@
            <MudItem sm="11" xs="11" md="11">
                <MudText Class="px-2">اختيار الفئة:</MudText>
                <MudSelect T="string" AnchorOrigin="Origin.BottomCenter" @bind-Value="@Category" Margin="Margin.Dense" Variant="Variant.Outlined">
                </MudSelect>
            </MudItem>
            @*<MudItem sm="11" xs="11" md="11">
            <MudText Typo="Typo.h6" Class="px-2">اسم الفئة الفرعية:</MudText>
            </MudItem>*@
            <MudItem sm="11" xs="11" md="11">
                <MudText Class="px-2">اختيار الفئة الفرعية:</MudText>
                <MudSelect T="string" AnchorOrigin="Origin.BottomCenter" @bind-Value="@SubCategory" Margin="Margin.Dense" Variant="Variant.Outlined">
                </MudSelect>
            </MudItem>
            <MudItem sm="11" xs="11" md="11">
                <MudText Class="px-2">عنوان الموضوع:</MudText>
                <MudTextField Margin="Margin.Dense" T="String" Variant="Variant.Outlined" InputType="InputType.Text" />
            </MudItem>
            <MudItem sm="11" xs="11" md="11">
                <MudText Class="px-2">صورة الموضوع:</MudText>
                
                <table>
                    @foreach (var item in filesBase64)
                    {
                        <tr>
                            <td>
                                <img src="data:@item.fileDescription;base64,@item.fileContent" style="width:40px;height:40px" />
                                <span class="px-3">
                                    @item.fileName
                                </span>
                            </td>
                            <td>
                                <a download="@item.fileName" href="data:@item.fileDescription;base64,@item.fileContent" target="_blank">
                                    <MudIcon Icon="@Icons.Material.Filled.DownloadForOffline" Color="Color.Primary" Style="height:25px; width:25px" />
                                </a>
                                <MudLink Underline="Underline.None" Color="Color.Transparent" OnClick="@(e=>deleteFile(item))">
                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Dark" Style="height:23px; width:22px" />
                                </MudLink>
                            </td>
                        </tr>
                    }
                </table>
                <div class="custom-file">
                        <label class="btn custom-file-input custom-file-label" style="background-color:#00AF37;color:white;margin-left:40%;margin-right:40%" for="inputFile">
                            إضافة صورة
                        </label>
                        <InputFile class="custom-file-input" style="background-color:#eeeeee;visibility:hidden" multiple OnChange="OnChange" accept="image/png, image/jpeg, image/gif" id="inputFile" />
                    </div>
                
            </MudItem>
            <MudItem sm="11" xs="11" md="11">
                <MudText Class="px-2">كاتب الموضوع:</MudText>
                <MudTextField Margin="Margin.Dense" T="String" Variant="Variant.Outlined" InputType="InputType.Text" />
            </MudItem>
            <MudItem sm="11" xs="11" md="11">
                <MudText Class="px-2">نبذة عن الموضوع:</MudText>
                <MudTextField Margin="Margin.Dense" Lines="5" T="String" Variant="Variant.Outlined" InputType="InputType.Text" />
            </MudItem>
            <MudItem sm="11" xs="11" md="11">
                <MudText Class="px-2">عنوان فرعي:</MudText>
                <MudTextField Margin="Margin.Dense" T="String" Variant="Variant.Outlined" InputType="InputType.Text" />
            </MudItem>
            <MudItem sm="11" xs="11" md="11">
                <MudText Class="px-2">موضوع العنوان الفرعي:</MudText>
                <MudTextField Margin="Margin.Dense" Lines="5" T="String" Variant="Variant.Outlined" InputType="InputType.Text" />
            </MudItem>
            <MudItem sm="11" xs="11" md="11">
                <MudButton DisableElevation="true" FullWidth Variant="Variant.Filled" Color="Color.Primary" Class="mt-1">حفظ</MudButton>
                @*<MudButton DisableElevation="true" OnClick="Cancelbtn" Variant="Variant.Outlined" Color="Color.Primary" Class="demo-form-button">@_localizer["lbl_Cancelbtn"]</MudButton>*@
            </MudItem>
        </MudGrid>
    </MudPaper>
</div>
@code {
    string SubCategory;
    string Category;
    bool isVisible;
    IReadOnlyList<IBrowserFile> files;
    List<ImageFile> filesBase64 = new List<ImageFile>();
    async Task OnChange(InputFileChangeEventArgs e)
    {
        files = e.GetMultipleFiles(); // get the files selected by the users
        foreach (var file in files)
        {
            var format = file.ContentType;
            var imageInfo = new ImageFile();
            Stream stream1 = file.OpenReadStream();
            MemoryStream ms = new MemoryStream();
            await stream1.CopyToAsync(ms);
            stream1.Close();
            var base64 = Convert.ToBase64String(ms.ToArray());
            filesBase64.Add(new ImageFile
                {
                    fileContent = base64,
                    fileDescription = format,
                    fileName = file.Name
                }); // convert to a base64 string!!

        }
    }
    void deleteFile(ImageFile base64)
    {
        int x = filesBase64.IndexOf(base64);
        filesBase64.RemoveAt(x);
        StateHasChanged();
    }
}
