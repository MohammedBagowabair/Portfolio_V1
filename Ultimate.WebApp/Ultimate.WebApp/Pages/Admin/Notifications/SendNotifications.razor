@page "/send notifications"

@inject IUserService userService
@inject IStringLocalizer<Resource> _localizer

@inject INotificationServices notificationServices
@inject ISnackbar Snackbar
<style>
    .fontTitle {
    @font_Title
    }

    .fontContent {
    @font_Content
    }
    .mud-icon-button {
        color: #4aa47e;
    }
    .mud-table-cell {
        border-bottom: 1px solid #4b4848;
    }
      .mud-icon-default {
        color: #c8cacd;
    }

    .mud-ltr {
        direction: inherit !important;
    }
    .mud-table-pagination-select .mud-input .mud-input-root {
        color: white;
    }
</style>
<EditForm Model="@notification" OnValidSubmit="sendNotifications">
    <DataAnnotationsValidator />
    <MudGrid Spacing="4" Class="mx-1" Justify="Justify.SpaceBetween">
        <MudOverlay Visible="isVisible" DarkBackground="true" ZIndex="9999">
            <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
        </MudOverlay>
        @*<MudPaper Style="background-color:#424242;width:100%;height:230px;" Class="" Elevation="0">*@
       
      
                      
            <MudItem xs="11" sm="8" md="6">
            <MudGrid>
                <MudItem xs="11" sm="11" md="11">
                    <MudRadioGroup @bind-SelectedOption="notification.content_type" For="@(()=>notification.content_type)">
                        <MudText Class="fontContent mb-2 mt-5 " Color="Color.Secondary" Typo="Typo.body1">@_localizer["lbl_NotificationType"]</MudText>
                        <MudRadio Option="@("text")" Color="Color.Primary" UnCheckedColor="Color.Secondary"><span class="fontContent" style="color:#c8cacd">@_localizer["lbl_NotificationTypeText"]</span></MudRadio>
                        <MudRadio Option="@("media")" Color="Color.Primary" UnCheckedColor="Color.Secondary"><span class="fontContent" style="color:#c8cacd">@_localizer["lbl_NotificationTypeMedia"]</span></MudRadio>
                       
                    </MudRadioGroup>
                </MudItem>
                 <MudItem xs="11" sm="11" md="11">
            
            @if (notification.content_type == "media")
            {


                if (files == null)
                {
                            <div Style="width:100%;height:250px;color:#c8cacd" class="border-2 border-dashed pa-1">
                        <MudText Align="Align.Center" Class="pa-3">
                            <MudIcon Color="Color.Primary" Icon="@Icons.Material.Filled.CloudUpload" Style="height:150px;width:150px" />
                            @*<MudImage Src="images/uplo.png" Width="130" Height="130" />*@
                            <MudText Class="mt-0 fontContent" Color="Color.Primary">@_localizer["lbl_attachImage"]</MudText>
                        </MudText>
                                
                    </div>
                }
                else
                {

                    <MudPaper Style="width:100%;height:250px;color:#4aa47e;" Class="d-flex flex-column  border-2 border-dashed pa-1" Elevation="0">

                     @*   @foreach (var item in filesBase64)
                        {*@


                            @if(notification.content!=null){

                            

                                <img src="data:@notification.mime;base64,@notification.content" style="width:200px;height:200px;margin-left:auto; margin-right:auto;margin-top:10px;" />


                                    <span class="px-3 mt-2 fontContent" style="color:#c8cacd; margin-left:auto; margin-right:auto;">
                                @notification.fileName
                            </span>

                            }
                            @*<MudLink Underline="Underline.None" Color="Color.Transparent" OnClick="@(e=>deleteFile(item))">
                <MudIcon Icon="@Icons.Material.Filled.Delete" Color="Color.Secondary" Style="height:23px; width:22px" />
                </MudLink>*@

                            @*<img src="data:@item.fileDescription;base64,@item.fileContent" style="width:100%;height:100%" />*@
                        @*}*@

                    </MudPaper>

                }

                <MudText Typo="Typo.body1" Class="mt-2 fontContent" Color="Color.Error">@imageValidations</MudText>
                <div class="custom-file pt-5">
                    <label class="btn custom-file-input custom-file-label fontContent" style="color:#c8cacd;background-color:#4aa47e;margin-left:43%;margin-right:43%" for="inputFile">
                                @_localizer["lbl_Select"]
                    </label>
                    <InputFile class="custom-file-input" style="background-color:#eeeeee;visibility:hidden" OnChange="OnChange" accept="application/pdf, image/png, image/jpeg, image/gif" id="inputFile" />

                </div>
            }
           
        </MudItem>
                <MudItem xs="11" sm="11" md="11">
                    <MudTextField @bind-Value="notification.description" Lines="4" Margin="Margin.Dense" Placeholder=@(notification.content_type=="text"?_localizer["lbl_txt"]:_localizer["lbl_Description"]) Class=" fontContent" Variant="Variant.Outlined" Style="color:#c8cacd"></MudTextField>

                    <MudText Typo="Typo.body1" Class="fontContent" Color="Color.Error">@(notification.content_type == "text"?textValidations:"")</MudText>
                       
                </MudItem>
            </MudGrid>


        </MudItem>

       
           
        <MudItem xs="11" sm="11" md="11">
                <MudText Class="fontContent" Color="Color.Secondary" Typo="Typo.body1">@_localizer["lbl_Users"]</MudText>
            <MudText Typo="Typo.body1" Class="fontContent" Color="Color.Error">@UserValidations</MudText>
               </MudItem>
                
               @if(users!=null){
           @*        <MudItem xs="11" sm="11" md="11">
                            <MudText Typo="Typo.body1" Class="fontContent" Color="Color.Error">@UserValidations</MudText>
                        </MudItem>*@
               
            <MudItem xs="11" sm="11" md="11">
           
            <MudTable Items="users.Content" Context="users" Breakpoint="Breakpoint.Xs" T="UsersModel" Class="mt-3" Style="background-color:#393939;" Height="300px" Filter="new Func<UsersModel,bool>(SearchFunc)" MultiSelection=true @bind-SelectedItems="selectedUsers">
                 @*   <PagerContent>

                        <MudTablePager RowsPerPageString="مستخدمين" PageSizeOptions="new int[]{5, 10,15}" Style="border-top:1px solid #4b4848 ;color:white" />

                    </PagerContent>*@
                <ToolBarContent>
                        <MudItem xs="7" sm="6" md="6">
                            <MudTextField @bind-Value="searchString" Margin="Margin.Dense" Placeholder=@_localizer["lbl_SearchForUser"] Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class=" fontContent" Variant="Variant.Outlined" Style="color:#c8cacd"></MudTextField>
                        </MudItem>
                        
                 
                    </ToolBarContent>
                <ColGroup>
                        <col width="70px" />
                        <col />
                </ColGroup>
                <HeaderContent>
                    <MudTh Class="fontContent" Style="border-bottom:1px solid #4b4848"><b style=" color:#c8cacd">@_localizer["lbl_User"]</b></MudTh>
               



                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@_localizer["lbl_User"]" Class="fontContent" Style="color:#c8cacd;border-bottom:1px solid #4b4848">@users.email</MudTd>
                 
                </RowTemplate>
            </MudTable>
        </MudItem>
            <MudItem xs="11" sm="11" md="11">
                <MudButton Variant="Variant.Filled" Size="Size.Large" Color="Color.Primary" Class="mt-1 px-10 fontContent" OnClick="sendNotifications" ButtonType="ButtonType.Submit">@_localizer["lbl_Send"]</MudButton>
                @*<MudButton Variant="Variant.Outlined" Size="Size.Medium" Color="Color.Primary" Class="mt-1 fontContent" OnClick="cancelExtend" hidden="@(!isMultiSelection)">@_localizer["lbl_Cancelbtn"]</MudButton>*@
            </MudItem>
    }
        else{
            <MudItem xs="11" sm="11" md="11">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" Class="mt-5" />
            </MudItem>
        }
        @*</MudPaper>*@
    </MudGrid>
</EditForm>
@code {
    NotificationsModel notification = new NotificationsModel();
    private bool isVisible;
    string font_Title;
    string font_Content;
    string selectedCulture = System.Globalization.CultureInfo.CurrentCulture.TextInfo.CultureName;
    ResponseModel<UsersModel> users;
    ResponseModel notificationsResult;
    private string searchString = "";
    private HashSet<UsersModel> selectedUsers = new HashSet<UsersModel>();
    IReadOnlyList<IBrowserFile> files;
    List<ImageFile> filesBase64 = new List<ImageFile>();
    ImageFile image = new ImageFile();
    long maxSize = 1024 * 1024 * 3;

    public string UserValidations;
    public string textValidations;
    public string imageValidations;
    protected override async Task OnInitializedAsync()
    {
        if (selectedCulture.Contains("ar"))
        {
            font_Content = "font-family:Noto Kufi Arabic;";
            font_Title = "font-family:Noto Kufi Arabic;";

        }
        else if (selectedCulture.Contains("en"))
        {
            font_Content = "font-family:DROID;";
            font_Title = "font-family:Forte;";
        }
        await getUsers();
    }
    public async Task getUsers()
    {
        try
        {
            users = await userService.GetAllUsers();
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
    }
    async Task OnChange(InputFileChangeEventArgs e)
    {
        files = e.GetMultipleFiles(); // get the files selected by the users
        imageValidations = string.Empty;
        foreach (var file in files)
        {
            filesBase64.Clear();
            var format = file.ContentType;
            var imageInfo = new ImageFile();
            Stream stream1 = file.OpenReadStream(maxSize);
            MemoryStream ms = new MemoryStream();
            await stream1.CopyToAsync(ms);
            stream1.Close();
            var base64 = Convert.ToBase64String(ms.ToArray());
            notification.content = base64;
            notification.fileName = file.Name;
            notification.mime = format;
            //filesBase64.Add(new ImageFile
            //    {
            //        fileContent = base64,
            //        fileDescription = format,
            //        fileName = file.Name
            //    }); // convert to a base64 string!!

        }
        //if (filesBase64.Count != 0)
        //{
        //    msg = string.Empty;
        //}
    }
    private bool SearchFunc(UsersModel user)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (user.email.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }
    async Task sendNotifications()
    
    {
     

        if (selectedUsers.Count() == 0 && notification.content_type == "text" && string.IsNullOrEmpty(notification.description))
        {
            UserValidations = _localizer["lbl_UserValidations"];
            textValidations = _localizer["lbl_textValidations"];
            StateHasChanged();
        }
        else if (selectedUsers.Count() == 0 && notification.content_type == "media" && string.IsNullOrEmpty(notification.content))
        {
            UserValidations = _localizer["lbl_UserValidations"];
            imageValidations = _localizer["lbl_imageValidations"];
            //textValidations = "يجب ادخال النص";
            StateHasChanged();
        }
        else if (selectedUsers.Count() != 0 && notification.content_type == "media" && string.IsNullOrEmpty(notification.content))
        {
            UserValidations = string.Empty;
            //textValidations = "يجب ادخال النص";
            imageValidations = _localizer["lbl_imageValidations"];
            StateHasChanged();
        }
        else if (selectedUsers.Count() != 0 && notification.content_type == "text" && string.IsNullOrEmpty(notification.description))
        {
            UserValidations = string.Empty;
            textValidations = _localizer["lbl_textValidations"];
            StateHasChanged();
        }
        else if (selectedUsers.Count() == 0 && notification.content_type == "text" && !string.IsNullOrEmpty(notification.description))
        {
            UserValidations = _localizer["lbl_UserValidations"];
            textValidations = string.Empty;
            StateHasChanged();

        }
        else if (selectedUsers.Count() == 0 && notification.content_type == "media" && !string.IsNullOrEmpty(notification.content))
        {
            UserValidations = _localizer["lbl_UserValidations"];
            textValidations = string.Empty;
            StateHasChanged();

        }
        else{
            UserValidations = string.Empty;
            textValidations = string.Empty;
            imageValidations=string.Empty;
            isVisible = true;
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Configuration.ShowCloseIcon = false;
            await Task.Delay(1000);
            //Console.WriteLine($"count {selectedUsers.Count()}-image {filesBase64.Count()}");
            //Console.WriteLine($"file name {notification.fileName}-file memi {notification.mime}-  file content {notification.content}");
            try
            {

                foreach (var item in selectedUsers)
                {

                    notification.userIds.Add(item.Id);
                    //userIds.ForEach((x)=>Console.WriteLine($"xxxx:{x}"));
                }
                notificationsResult = await notificationServices.SendNotification(notification);
                isVisible = false;
                Snackbar.Add(_localizer["lbl_NotificationsSending"], Severity.Success);
                selectedUsers.Clear();
                filesBase64.Clear();
                files = null;
                notification = new NotificationsModel();
                Console.WriteLine($"extend -items {notification.userIds.Count()}");
              
            }
            catch(Exception e){
                Console.WriteLine($"{e.Message}, {e.StackTrace}");
                isVisible = false;
                Snackbar.Add(_localizer["msg_Fail"], Severity.Normal);
            }
    }
        
    }
    void deleteFile(ImageFile base64)
    {

    }
}
