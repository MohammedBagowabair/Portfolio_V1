    async Task DeletedPackage()
    {
        try
        {
            result = await packagesService.GetPackages();
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
    }
    async void deletePackage(int packageId)
    {
        var parameters = new DialogParameters();
        parameters.Add("title", _localizer["lbl_DeletePackage"].ToString());
        parameters.Add("deleteConfirmation", _localizer["lbl_CofirmDeletePackage"].ToString());
        parameters.Add("buttonText", _localizer["lbl_Deletebtn"].ToString());
        parameters.Add("Id", packageId);
        parameters.Add("OnDeleted", EventCallback.Factory.Create(this, DeletedPackage));
        //parameters.Add("menuName", name);
        //parameters.Add("botId", botId);
        var options = new DialogOptions { FullWidth = true };
