@inject NavigationManager navigationManager
@inject IPackagesService packagesService
@inject IPeriodService PeriodService
@inject IStringLocalizer<Resource> _localizer
@inject IDialogService DialogService
@inject CustomHttp Http
@page "/ViewSubscriptionPackages"
<style>
    .fontTitle {
    @font_Title
    }

    .fontContent {
    @font_Content
    }
</style>
<PageTitle>Subscription Package</PageTitle>
<MudGrid Spacing="1" Justify="Justify.SpaceBetween" Class="mt-5">
    <MudOverlay Visible="isVisible" DarkBackground="true" ZIndex="9999">
        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
    </MudOverlay>
    @if (result != null)
    {
        <MudItem xs="11" sm="11" md="8">
            <MudGrid>


                <MudItem xs="12" sm="12" md="12">
                    <MudButton Variant="Variant.Filled" OnClick="addPackages" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" Class="fontContent">@_localizer["lbl_AddPackage"] </MudButton>
                </MudItem>
                @foreach (PackagesModel pck in result.Content)
                {


                    @*pck.periodId*@
                    if (pck.status == "free")
                    {
                        <MudItem xs="11" sm="6" md="4">

                            <MudCard Elevation="1" Outlined="true" Style="background-color:#424242;">

                                @if (selectedCulture.Contains("en"))
                                {
                                    <div style="background-color:#4aa47e; color:white; width:30%">
                                        <MudText Align="Align.Center" Class="fontContent" Color="Color.Secondary">
                                            @pckStatus.Where(x=>x.status==pck.status).FirstOrDefault()?.status
                                        </MudText>
                                    </div>
                                }
                                else if (selectedCulture.Contains("ar"))
                                {
                                    <div style="background-color:#4aa47e; color:white; width:30%">
                                        <MudText Align="Align.Center" Class="fontContent" Color="Color.Secondary">
                                            @pckStatus.Where(x=>x.status==pck.status).FirstOrDefault()?.value
                                        </MudText>
                                    </div>
                                }



                                <MudCardContent>

                                    <MudText Align="Align.Center">
                                        <MudImage Height="80" Width="80" Src="images/package.png" Alt="subscription Package" Class="mt-3" />
                                    </MudText>
                                    <MudText Typo="Typo.h6" Align="Align.Center" Class="mt-3 fontContent" Color="Color.Secondary">
                                        @if (selectedCulture.Contains("ar"))
                                        {
                                            <span>@pck.name</span>
                                        }
                                        else
                                        {
                                            <span>@pck.foreignName</span>
                                        }
                                    </MudText>
                                    @{
                                        double totalPrice;
                                        totalPrice = pck.packageServices.Sum(x => x.price * x.qty);

                                    }



                                    @if (pck.disCount > 0)
                                    {
                                        double PriceAfterDiscount;
                                        PriceAfterDiscount = totalPrice - totalPrice * (pck.disCount / 100);
                                        <div class="d-flex flex-row mt-3 gap-1 justify-center">
                                            <MudText Typo="Typo.h6" Color="Color.Primary" Align="Align.Center" Class="fontContent">$@PriceAfterDiscount</MudText>
                                            <MudText Align="Align.Center" Class="mt-1 fontContent" Color="Color.Secondary"><sub><del>@totalPrice</del></sub></MudText>
                                        </div>
                                        <div class="d-flex flex-row mt-9">
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" Class="me-2"></MudIcon>
                                            <MudText Align="Align.Start" Style="font-size:18px;" Class="fontContent mt-n1" Color="Color.Secondary">@_localizer["lbl_Discount"] @pck.disCount%</MudText>
                                        </div>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.h6" Align="Align.Center" Color="Color.Primary" Class="mt-3 fontContent">$@totalPrice</MudText>
                                        <div class="d-flex flex-row mt-9">
                                            <MudIcon Icon="@Icons.Material.Filled.Close" Color="Color.Secondary" Size="Size.Small" Class="me-2"></MudIcon>
                                            <MudText Align="Align.Start" Style="font-size:18px;" Class="fontContent mt-n1" Color="Color.Secondary">@_localizer["lbl_Discount"] @pck.disCount%</MudText>
                                        </div>
                                    }
                                    <div class="d-flex flex-row mt-3">

                                        @if (periodlist.Where(x => x.id == pck.periodId).FirstOrDefault().type == "Monthly")
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" Class="me-2"></MudIcon>
                                            <MudText Align="Align.Start" Style="font-size:18px;" Color="Color.Secondary" Class="fontContent mt-n1">@_localizer["lbl_Monthly"]</MudText>
                                        }
                                        else if (periodlist.Where(x => x.id == pck.periodId).FirstOrDefault().type == "Yearly")
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" Class="me-2"></MudIcon>
                                            <MudText Align="Align.Start" Style="font-size:18px;" Color="Color.Secondary" Class="fontContent mt-n1">@_localizer["lbl_Yearly"]</MudText>
                                        }
                                    </div>
                                    <div class="d-flex flex-row mt-3">
                                        <MudIcon Icon="@Icons.Material.Filled.Check" Color="Color.Primary" Size="Size.Small" Class="me-2"></MudIcon>
                                        <MudText Align="Align.Start" Style="font-size:18px;" Color="Color.Secondary" Class="fontContent mt-n1">@_localizer["lbl_Service1"]</MudText>
                                    </div>




                                    <div Class="d-flex justify-space-between mt-11">
                                        <MudHidden Breakpoint="Breakpoint.MdAndUp" Invert="true">
                                            <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth DisableElevation OnClick="()=>ShowDetails(result.Content.IndexOf(pck),pck.id)" Class="fontContent">@_localizer["lbl_Details"]</MudButton>
                                        </MudHidden>
                                        <MudHidden Breakpoint="Breakpoint.SmAndDown" Invert="true">
                                            <MudButton Color="Color.Primary" Variant="Variant.Filled" FullWidth DisableElevation OnClick="()=>DetailsinSm(result.Content.IndexOf(pck),pck.id)" Class="fontContent">@_localizer["lbl_Details"]</MudButton>
                                        </MudHidden>
                                        <div class="d-flex flex-row-reverse gap-1">
                                            @*<MudMenu Icon="@Icons.Material.Filled.MoreVert" DisableElevation="true">
                                <MudMenuItem OnTouch="()=>EditPackage(pck.id)" OnClick="()=>EditPackage(pck.id)">@_localizer["lbl_BtnEdit"]</MudMenuItem>
                                <MudMenuItem OnTouch="()=>deletePackage(pck.periodId)" OnClick="()=>deletePackage(pck.periodId)">@_localizer["lbl_Deletebtn"]</MudMenuItem>
                                </MudMenu>*@
                                            <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Medium" OnClick="()=>EditPackage(pck.id)" Color="Color.Secondary" />
                                            @* <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Medium" Color="Color.Primary" />
                                <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Medium" Color="Color.Primary" />*@
                                        </div>
                                    </div>
                                </MudCardContent>
                            </MudCard>

                        </MudItem>
                    }
                }
                @foreach (PackagesModel pckb in result.Content)
                {

                    if (pckb.status == "basic")
                    {
                        @*pck.periodId*@

                        <MudItem xs="11" sm="6" md="4">

                            <MudCard Elevation="1" Outlined="true" Style="background-color:#424242;">

                                @if (selectedCulture.Contains("en"))
                                {
                                    <div style="background-color:#4aa47e; color:white; width:30%">
