<EditForm Model="packages" OnValidSubmit="AddPackages">
    <DataAnnotationsValidator />
    <MudOverlay Visible="isVisible" DarkBackground="true" ZIndex="9999">
        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
    </MudOverlay>

    <MudGrid Justify="Justify.FlexStart" Class="mt-5 ms-5" Spacing="1">
        <MudItem xs="11" md="11" sm="11">
            @*<MudText Typo="Typo.h4">هذي الصفحة قيد الانشاء</MudText>*@
            <MudText Typo="Typo.h4" Class="pb-6 fontContent" Color="Color.Secondary">@title</MudText>
        </MudItem>

        <MudItem xs="11" sm="11" md="11">
            <MudText Class="fontContent" Color="Color.Secondary"><b>@_localizer["lbl_PackageName"] </b></MudText>
        </MudItem>
        <MudItem xs="11" md="7" sm="8" Class="mb-5">
            <MudTextField @bind-Value="packages.name" Variant="Variant.Outlined" Margin="Margin.Dense" For="()=>packages.name" Class="fontContent" Style="color:#c8cacd"></MudTextField>
        </MudItem>

        <MudItem xs="11" sm="11" md="11">
            <MudText Class="fontContent" Color="Color.Secondary"><b>@_localizer["lbl_ForeignPackageName"] </b></MudText>
        </MudItem>
        <MudItem xs="11" md="7" sm="8" Class="mb-5">
            <MudTextField @bind-Value="packages.foreignName" Variant="Variant.Outlined" Margin="Margin.Dense" For="()=>packages.foreignName" Class="fontContent" Style="color:#c8cacd"></MudTextField>
        </MudItem>
        
        <MudItem xs="11" sm="11" md="11">
            <MudText Class="fontContent" Color="Color.Secondary"><b>@_localizer["lbl_Description"] </b></MudText>
        </MudItem>
        <MudItem xs="11" md="7" sm="8" Class="mb-5">
            <MudTextField @bind-Value="packages.description" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" For="()=>packages.description" Class="fontContent" Style="color:#c8cacd"></MudTextField>
        </MudItem>

        <MudItem xs="11" sm="11" md="11">
            <MudText Class="fontContent" Color="Color.Secondary"><b>@_localizer["lbl_ForeignDescription"] </b></MudText>
        </MudItem>
        <MudItem xs="11" md="7" sm="8" Class="mb-5">
            <MudTextField @bind-Value="packages.foreignDescription" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" For="()=>packages.foreignDescription" Class="fontContent" Style="color:#c8cacd"></MudTextField>
        </MudItem>

        <MudItem xs="11" md="7" sm="8" Class="mb-5">
            <MudRadioGroup @bind-SelectedOption="packages.status" Style="color:#c8cacd" Class="fontContent">
                <MudText Class="font_Content" Color="Color.Secondary"><b>@_localizer["lbl_Status2"]</b></MudText>
                @if (selectedCulture.Contains("ar"))
                {
                    @foreach (var status in pckStatus ?? Array.Empty<PackageStatus>())
                    {

                        <MudRadio Option=@status.status Color="Color.Primary" UnCheckedColor="Color.Secondary"  Class="fontContent"><span style ="color:white" class="fontContent">@status?.value</span></MudRadio>

                    }
                }
                @if (selectedCulture.Contains("en"))
                {
                    @foreach (var status in pckStatus ?? Array.Empty<PackageStatus>())
                    {

                        <MudRadio Option=@status.status Color="Color.Primary" UnCheckedColor="Color.Secondary"  Class="fontContent"><span style ="color:white" class="fontContent">@status?.status</span></MudRadio>

                    }
                }

            </MudRadioGroup>
        </MudItem>
        <MudItem xs="11" sm="11" md="11">
            <MudText Class="fontContent" Color="Color.Secondary"><b>@_localizer["lbl_PackageDiscount"]</b></MudText>
        </MudItem>
        <MudItem xs="11" md="7" sm="8" Class="mb-5">
            <MudTextField @bind-Value="packages.disCount" InputType="InputType.Number" Variant="Variant.Outlined" Margin="Margin.Dense" For="()=>packages.disCount" Class="fontContent" Style="color:#c8cacd"></MudTextField>
        </MudItem>

        @if (result != null)
        {
            <MudItem xs="11" sm="11" md="11">
                <MudText Class="fontContent" Color="Color.Secondary"><b>@_localizer["lbl_Period"]</b></MudText>
            </MudItem>
            <MudItem xs="11" md="7" sm="8" Class="mb-5">

                <MudSelect Variant="Variant.Outlined" @bind-Value="packages.periodId" Margin="Margin.Dense" For="()=>packages.periodId" Style="color:#c8cacd" Class="fontContent">

                    @foreach (var period in result.Content)
                    {
                        <MudSelectItem Value="@(period.id)"><span style ="color:white" class="fontContent">@period.name</span></MudSelectItem>



                    }

                </MudSelect>

            </MudItem>

            <MudItem xs="11" md="7" sm="8" Class="mb-5">

                <MudDataGrid T="packageServicesModel" Items="packages.packageServices" ReadOnly="true" Dense="true" SortMode="@SortMode.None" EditMode="DataGridEditMode.Cell" GroupStyle="color:#c8cacd" RowStyle="color:#c8cacd"
                         StartedEditingItem="@StartedEditingItem" CanceledEditingItem="@CanceledEditingItem" CommittedItemChanges="@CommittedItemChanges"
                         Bordered="false" EditTrigger="@(_editTriggerRowClick ? DataGridEditTrigger.OnRowClick : DataGridEditTrigger.Manual)" Style="background-color:#393939;" Class="fontContent">

                    <Columns>

                        <PropertyColumn Property="p=>p.displayedserviceName" Title=@_localizer["lbl_Service"] Style="border-bottom:1px solid #4b4848;color:#c8cacd" Class="fontContent" CellStyle="color:#c8cacd" HeaderStyle="color:#c8cacd">
                            @*<EditTemplate Context=ctx>
                                <MudSelect @bind-Value="ctx.Item.serviceName" Style="color:#c8cacd" Class="fontContent">

                                    @foreach (var srv in servicesModel ?? Array.Empty<ServicesModel>())

                                    {
                                        <MudSelectItem T="string" Value="@srv.serviceApi"><span style ="color:white" class="fontContent">@srv.serviceName</span></MudSelectItem>
                                    }
                                </MudSelect>
                            </EditTemplate>*@
                        </PropertyColumn>


                        <PropertyColumn Property="p=>p.price" Title=@_localizer["lbl_Price"] Style=" border-bottom:1px solid #4b4848;color:#c8cacd" Class="fontContent" CellStyle="color:#c8cacd" HeaderStyle="color:#c8cacd"></PropertyColumn>
                        <PropertyColumn Property="p=>p.qty" Title=@_localizer["lbl_Qty"] Style="border-bottom:1px solid #4b4848;color:#c8cacd" Class="fontContent" CellStyle="color:#c8cacd" HeaderStyle="color:#c8cacd"></PropertyColumn>

                    </Columns>
                </MudDataGrid>
            </MudItem>
            @*<MudItem xs="11" md="7" sm="8" Class="mb-5">*@
            @*<div class="d-flex flex-row gap-2 mb-5">*@
            <MudGrid Spacing="2" Class="mb-2">

                <MudItem xs="4" sm="2" md="2">
                    <MudSelect Label="@_localizer["lbl_Service"]" @bind-Value="srvName" Style="color:#c8cacd" Class="fontContent" Placeholder=@_localizer["lbl_ChooseService"]>

                        @foreach (var srv in servicesModel ?? Array.Empty<ServicesModel>())

                        {
                            <MudSelectItem T="string" Value="@srv.serviceApi"><span style="color:#c8cacd" class="fontContent">@srv.serviceName</span></MudSelectItem>
                        }
                    </MudSelect>
                    @*<MudTextField @bind-Value="srvName" Label=@_localizer["lbl_Service"]></MudTextField>*@
                </MudItem>
                <MudItem xs="2" sm="2" md="2">
                    <MudTextField @bind-Value="srvprice" Label=@_localizer["lbl_Price"] Class="fontContent" Style="color:#c8cacd">></MudTextField>
                </MudItem>
                <MudItem xs="2" sm="2" md="2">
                    <MudTextField @bind-Value="Qty" InputType="InputType.Number" Label=@_localizer["lbl_Qty"] Class="fontContent" Style="color:#c8cacd">></MudTextField>
                </MudItem>
                <MudItem xs="1" sm="2" md="2">
                    <MudIconButton Icon="@Icons.Material.Outlined.Save" OnClick="addService" Color="Color.Primary" Style="position:relative;top:20px;" />
                </MudItem>

            </MudGrid>
            @*</div>*@
            @*</MudItem>*@
            @*<MudItem xs="11" md="8" sm="8">
        <h1>@packages.periodId</h1>
        </MudItem>*@

        }
        else
        {
            <MudItem sm="11" md="11" xs="11">
                <MudText Class="fontContent" Color="Color.Secondary">loading...</MudText>
            </MudItem>
        }
        <MudItem md="11">
            <MudText Color="Color.Error" Class="fontContent">@validatedsrv</MudText>
        </MudItem>
        <MudItem sm="11" xs="11" md="11" Class="mb-2">
            <MudButton DisableElevation="true" Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Submit" Class="mb-2 fontContent">@name_btn</MudButton>
            <MudButton DisableElevation="true" Variant="Variant.Filled" Color="Color.Secondary" Class="mb-2 fontContent" OnClick="CancelBtn">@_localizer["lbl_Cancelbtn"]</MudButton>
        </MudItem>
    </MudGrid>

</EditForm>

@code {
    PackagesModel packages = new PackagesModel();
    ResponsGeneric<PackagesModel> package;
    [Parameter]
    public int id { set; get; }
    string title;
    ResponseModel<PeriodModel> result;
    private string pckResult;

    ResponseModel<PeriodModel> serviceResult;
    List<ServicePriceModel> servicePrices = new List<ServicePriceModel>();
    public string name_btn { set; get; }
    int periodId;
    string srvName;
    string validatedsrv;
    double srvprice;
    int Qty;
    private bool isVisible;
    string selectedCulture = System.Globalization.CultureInfo.CurrentCulture.TextInfo.CultureName;
    private ServicesModel[]? servicesModel;
    private PackageStatus[]? pckStatus;
    private bool _readOnly;
    private bool _isCellEditMode;
    private List<string> _events = new();
    private bool _editTriggerRowClick;
    string font_Title;
    string font_Content;
    protected override async Task OnParametersSetAsync()
    {
        package = await packagesService.GetPackageById(id);
        if (package.Content != null)
        {
            name_btn = _localizer["lbl_BtnEdit"];
            title = package.Content.name;
            packages = package.Content;
            if (packages.packageServices.Count>0)
            {
                foreach (var srv in packages.packageServices)
                {

                    if (selectedCulture.Contains("ar"))
                    {
                        if (srv.serviceName == "Client")
                        {
                            srv.displayedserviceName = "عميل";
                        }
                        else if (srv.serviceName == "Menu")
                        {
                            srv.displayedserviceName = "قائمة";
                        }
                        else
                        {
                            srv.displayedserviceName = srv.serviceName;
                        }
                    }
                    else
                    {
                        srv.displayedserviceName = srv.serviceName;
                    }


                   
                }
            }

        }
        else
        {
            name_btn = _localizer["lbl_BtnSave"];
            title = _localizer["lbl_CreatePackage"];
        }

    }
    protected override async Task OnInitializedAsync()
    {
        //name_btn = _localizer["lbl_BtnSave"];
        //result = await packagesService.GetPackages();
        pckStatus = await Http.HttpClient.GetFromJsonAsync<PackageStatus[]>("PackageStatus/PackagesStatus.json");
        try{
            result = await periodService.GetAll();
        }
       catch(Exception e){
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
       }
        if (selectedCulture.Contains("en"))
        {
            font_Content = "font-family:DROID;";
            font_Title = "font-family:Forte;";
            servicesModel = await Http.HttpClient.GetFromJsonAsync<ServicesModel[]>("Service/ServicesEN.json");
            //srvName = "numbers";
        }
        else if (selectedCulture.Contains("ar"))
        {
            font_Content = "font-family:Noto Kufi Arabic;";
            font_Title = "font-family:Noto Kufi Arabic;";
            servicesModel = await Http.HttpClient.GetFromJsonAsync<ServicesModel[]>("Service/Services.json");
            //srvName = "أرقام";
        }
        Console.WriteLine(result.Message);


    }

    void addService()
    {
        Console.WriteLine($"srvname {srvName}");
        var srvInfo = new packageServicesModel() { serviceName = srvName, price = srvprice, qty = Qty };
       
        if (selectedCulture.Contains("ar"))
        {
            if (srvInfo.serviceName == "Client")
            {
                srvInfo.displayedserviceName = "عميل";
            }
            else if (srvInfo.serviceName == "Menu")
            {
                srvInfo.displayedserviceName = "قائمة";
            }
            else{
                srvInfo.displayedserviceName = srvInfo.serviceName;
            }
        }
        else{
            srvInfo.displayedserviceName = srvInfo.serviceName;
        }
        packages.packageServices.Add(srvInfo);
        srvName = string.Empty;
        srvprice = 0;
        Qty = 0;
    }
    void StartedEditingItem(packageServicesModel item)
    {
        _events.Insert(0, $"Event = StartedEditingItem, Data = {System.Text.Json.JsonSerializer.Serialize(item)}");
    }
    void CanceledEditingItem(packageServicesModel item)
    {
        _events.Insert(0, $"Event = CanceledEditingItem, Data = {System.Text.Json.JsonSerializer.Serialize(item)}");
    }
    void CommittedItemChanges(packageServicesModel item)
    {
        _events.Insert(0, $"Event = CommittedItemChanges, Data = {System.Text.Json.JsonSerializer.Serialize(item)}");
    }
    private async void AddPackages()
    {

        if (packages.packageServices.Count <= 0)
        {
            validatedsrv = _localizer["msg_PackageServiceRequired"];
        }
        else
        {
            isVisible = true;
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Configuration.ShowCloseIcon = false;

            await Task.Delay(1000);
            if (name_btn == _localizer["lbl_BtnSave"])
            {

                try
                {
                    Console.WriteLine("add");
                    //menudetails.botId = botId;
                    ResponsePost<PackagesModel> res = await packagesService.Create(packages);
                    pckResult = res.Message;
                    Console.WriteLine(res.Message);
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertSaved"], Severity.Success);
                    packages = new PackagesModel();
                    srvName = string.Empty;
                    srvprice = 0;
                    Qty = 0;
                    navigationManager.NavigateTo("/AdminManagement/2");
                    StateHasChanged();


                }
                catch (Exception e)
                {
                    Console.WriteLine($"{e.Message}, {e.StackTrace}");
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertFSaved"], Severity.Normal);
                    //packages = new PackagesModel();
                    StateHasChanged();
                }
            }
            else
            {
                try
                {
                    await packagesService.UpdatePackage(packages, packages.id);
                    isVisible = false;
                    name_btn = _localizer["lbl_BtnSave"];
                    title = _localizer["lbl_CreatePackage"];
                    Snackbar.Add(_localizer["msg_AlertModified"], Severity.Success);
                    packages = new PackagesModel();
                    navigationManager.NavigateTo("/AdminManagement/2");
                    StateHasChanged();

                }
                catch (Exception e)
                {
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertFModified"], Severity.Error);
                    //packages = new PackagesModel();
                    StateHasChanged();
                    Console.WriteLine($"{e.Message}, {e.StackTrace}");
                }
            }

        }
    }
    void CancelBtn()
    {
        navigationManager.NavigateTo("/AdminManagement/2");
    }
}
