@page "/confirm account"
@inject IUserService userService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> _localizer
<style>
    .fontTitle {
    @font_Title
    }

    .fontContent {
    @font_Content
    }

    .iti * {
        box-sizing: border-box;
        color: #c8cacd;
        margin-top: 3px;
    }
 
    .iti__dial-code {
    color: #4aa47e;
}

    .iti__country-list {
        border: none;
        background-color: #424242;
       
    }
    .iti--allow-dropdown input, .iti--allow-dropdown input[type=text], .iti--allow-dropdown input[type=tel], .iti--separate-dial-code input, .iti--separate-dial-code input[type=text], .iti--separate-dial-code input[type=tel] {
   
    background-color: transparent;
        margin-top: 10px !important;
   
}


    
</style>
<PageTitle>Confrim Number</PageTitle>
@if (isCodeSending)
{
    <NumberConfirmationCode number="@number" OnBacktoClients="@OnBacktoClients" />
}
else
{
    <MudOverlay Visible="isVisible" DarkBackground="true" ZIndex="9999">
        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
    </MudOverlay>
    <MudGrid Justify="Justify.Center" Class="mt-5">
        <MudItem xs="11" sm="10" md="8">
            <MudPaper Class="py-15" Style="background-color:#424242;box-shadow:9px 8px 200px -13px #4aa47e">
                <EditForm Model="@numberConfirmation" OnValidSubmit="sendCode" Class="px-5">
                    <DataAnnotationsValidator />
                    <MudGrid Justify="Justify.FlexStart">
                        <MudItem xs="11" sm="11" md="11">
                            <MudText Align="Align.Start" Class="ma-2 fontContent" Style="color:#c8cacd">@_localizer["lbl_NumberConfirmationText"]</MudText>

                        </MudItem>
                         <MudItem xs="11" sm="10" md="9">

                                <MudIntlTelInput Class="fontContent mx-2" Style="color:#c8cacd" @bind-Value="numberConfirmation.number" Margin="Margin.Dense" Variant="Variant.Outlined" For="@(()=>numberConfirmation.number)"></MudIntlTelInput>
                            @*<MudText Align="Align.Start" Typo="Typo.body1" Class="fontContent mx-2" Color="Color.Error">@validationMsg</MudText>*@

                        </MudItem>
                        <MudItem sm="11" xs="10" md="9">
                            <MudText Align="Align.Center">
                                <MudButton Color="Color.Primary" Class="px-10 mx-2 fontContent" Variant="Variant.Filled" Style="font-size:16px;color:white" ButtonType="ButtonType.Submit">@_localizer["lbl_Send"]</MudButton>
                            </MudText>
                        </MudItem>
                    </MudGrid>

                </EditForm>

               @* <MudForm Class="px-5">
                    <MudGrid Justify="Justify.FlexStart">


                        <MudItem xs="11" sm="11" md="11">

                           
                            <MudText Align="Align.Start" Class="ma-2 fontContent" Style="color:#c8cacd">@_localizer["lbl_NumberConfirmationText"]</MudText>

                        </MudItem>

                        <MudItem xs="11" sm="10" md="9">

                            <MudTextField Class="fontContent mx-2" Style="color:#c8cacd" @bind-Value="number" Margin="Margin.Dense" Variant="Variant.Outlined" Placeholder=@_localizer["lbl_NumberForConfirm"]></MudTextField>
                            <MudText Align="Align.Start" Typo="Typo.body1" Class="fontContent mx-2" Color="Color.Error">@validationMsg</MudText>

                        </MudItem>
                        <MudItem sm="11" xs="10" md="9">
                            <MudText Align="Align.Center">
                                <MudButton Color="Color.Primary" Class="px-10 mx-2 fontContent" Variant="Variant.Filled" Style="font-size:16px;color:white" OnClick="sendCode">@_localizer["lbl_Send"]</MudButton>
                            </MudText>
                        </MudItem>


                    </MudGrid>
                </MudForm>*@
            </MudPaper>
        </MudItem>
    </MudGrid>
    @*</MudPaper>*@
}

@code {
    NumberConfirmationsModel numberConfirmation = new NumberConfirmationsModel();
    string selectedCulture = System.Globalization.CultureInfo.CurrentCulture.TextInfo.CultureName;
    string font_Title;
    string font_Content;
    private bool isVisible;
    [Parameter]
    public EventCallback OnBacktoClients { set; get; }
    //bool error;
    //bool success;

    string number;
    string validationMsg;
    bool isCodeSending;

    protected override async Task OnInitializedAsync()
    {
        if (selectedCulture.Contains("en"))
        {
            font_Content = "font-family:DROID;";
            font_Title = "font-family:Forte;";
        }
        else
        {
            font_Content = "font-family:Noto Kufi Arabic;";
            font_Title = "font-family:Noto Kufi Arabic;";
        }
    }
    public async Task sendCode()
    {
         number = numberConfirmation.number.ToString().TrimStart('+');
    ;
        Console.WriteLine($"trim 1: {number};");
        //Console.WriteLine("confirm");
        //if (number == null)
        //{
        //    validationMsg = _localizer["lbl_NumberValidations"];
        //}
        //else
        //{


            validationMsg = string.Empty;
            isVisible = true;
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Configuration.ShowCloseIcon = false;
            await Task.Delay(1000);
            try
            {
                ResponsGeneric<bool> result = await userService.SendWhatsappVerifyCode(number);
                isCodeSending = true;
                isVisible = false;
                Snackbar.Add(_localizer["lbl_ConfrimCodeSending"], Severity.Success);
                //StateHasChanged();
            }
            catch (Exception e)
            {
                Console.WriteLine($"{e.Message}, {e.StackTrace}");
                isVisible = false;
                Snackbar.Add(_localizer["msg_Fail"], Severity.Normal);
                //StateHasChanged();
            }

        //}
        StateHasChanged();
    }
}
