    public async void HandelSubment()
    {
        isVisible = true;
        autoMessageModel.BotId = botId;
        autoMessageModel.MsgType = "1";
        autoMessageModel.Actionn = _events.getAction();
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomStart;
        Snackbar.Configuration.ShowCloseIcon = false;
        await Task.Delay(1000);
        if (name_btn == _localizer["lbl_BtnSave"])
        {
            ResponsePost<AutoMessageModel> autos;
            try
            {
                Console.WriteLine(autoMessageModel.Actionn);
                autos = await AutomessageService.Create(autoMessageModel);
                Console.WriteLine("pppppppp: "+ autos.Code);
                if (autos.Code == 0 )
                {
                    isVisible = false;
                    msgalert = _localizer["msg_AlertSaved"];
                    Snackbar.Add(msgalert, Severity.Success);
                    autoMessageModel = new AutoMessageModel();
                    auto = await AutomessageService.GetById(botId);
                    StateHasChanged();
                }
                else if(autos.Code == 3003){
                    isVisible = false;
                    msgalert = _localizer["msg_AlertSavedandUpdate"];
                    Snackbar.Add(msgalert, Severity.Success);
                    autoMessageModel = new AutoMessageModel();
                    auto = await AutomessageService.GetById(botId);
                    StateHasChanged();
                }
                else if(autos.Code == 4004){
                    isVisible = false;
                    msgalert = _localizer["msg_FSavePackageExpired"];
                    Snackbar.Add(msgalert, Severity.Error);
                    autoMessageModel = new AutoMessageModel();
                    auto = await AutomessageService.GetById(botId);
                    StateHasChanged();
                }
                else{
                    isVisible = false;
                    msgalert = _localizer["msg_AlertFSaved"];
                    Snackbar.Add(msgalert, Severity.Error);
                    auto = await AutomessageService.GetById(botId);
                    //autoMessageModel = new AutoMessageModel();
                    Console.WriteLine($"status code:{autos.Code},response:{autos.Message}");
                    StateHasChanged();
                }
            }
            catch (Exception e)
            {
                isVisible = false;
                msgalert = _localizer["msg_AlertFSaved"];
                Snackbar.Add(msgalert, Severity.Error);
                auto = await AutomessageService.GetById(botId);
                //autoMessageModel = new AutoMessageModel();
                StateHasChanged();
                Console.WriteLine($"{e.Message}, {e.StackTrace}");
            }

        }
        else
        {
            try
            {
                Console.WriteLine(autoMessageModel.Actionn);
                var res=await AutomessageService.Update(autoMessageModel);
                if (res.Code == 0)
                {
                    //Console.WriteLine("xxxxxxxxxxxxxx: " + x);
                    name_btn = _localizer["lbl_BtnSave"];
                    btnCancle = "invisible";
                    isVisible = false;
                    msgalert = _localizer["msg_AlertModified"];
                    Snackbar.Add(msgalert, Severity.Success);
                    //showCallAlert = false;
                    autoMessageModel = new AutoMessageModel();
                    auto = await AutomessageService.GetById(botId);
                    StateHasChanged();
                }
                else if (res.Code == 3003)
                {
                    //Console.WriteLine("xxxxxxxxxxxxxx: " + x);
                    name_btn = _localizer["lbl_BtnSave"];
                    btnCancle = "invisible";
                    isVisible = false;
                    msgalert = _localizer["msg_AlertModifiedandUpdate"];
                    Snackbar.Add(msgalert, Severity.Success);
                    //showCallAlert = false;
                    autoMessageModel = new AutoMessageModel();
                    auto = await AutomessageService.GetById(botId);
                    StateHasChanged();
                }
                else if (res.Code == 4004)
                {
                    //Console.WriteLine("xxxxxxxxxxxxxx: " + x);
                    name_btn = _localizer["lbl_BtnSave"];
                    btnCancle = "invisible";
                    isVisible = false;
                    msgalert = _localizer["msg_FModifiedPackageExpired"];
                    Snackbar.Add(msgalert, Severity.Error);
                    //showCallAlert = false;
                    autoMessageModel = new AutoMessageModel();
                    auto = await AutomessageService.GetById(botId);
                    StateHasChanged();
                }
                else{
                    isVisible = false;
                    msgalert = _localizer["msg_AlertFModified"];
                    auto = await AutomessageService.GetById(botId);
                    Snackbar.Add(msgalert, Severity.Error);
                    Console.WriteLine($"status code:{res.Code},response:{res.Message}");
                    StateHasChanged();
                }
            }
            catch (Exception e)
            {
                isVisible = false;
                msgalert = _localizer["msg_AlertFModified"];
                auto = await AutomessageService.GetById(botId);
                Snackbar.Add(msgalert, Severity.Error);
                StateHasChanged();
                Console.WriteLine($"eeeeeeeeeeeee99e: {e.Message}, {e.StackTrace}");
            }
        }

    }

