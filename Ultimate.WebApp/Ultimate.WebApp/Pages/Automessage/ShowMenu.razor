@inject IStringLocalizer<Resource> _localizer
@inject IEventsService _eventsService
@inherits EventsComponent
<style>
    .fontTitle {
    @font_Title
    }

    .fontContent {
    @font_Content
    }
</style>
<MudRTLProvider RightToLeft=@IsRTL>
    <MudDialog Style="background-color:#424242;box-shadow:0px 0px 100px -19px #4aa47e">
        <TitleContent>
            <div dir="@direction">
                <MudText Class="fontContent" Color="Color.Secondary" Typo="Typo.h5">@title : @menuname</MudText>
            </div>
        </TitleContent>
        <DialogContent>

            @*<MudText>@menuId</MudText>*@


            @foreach (var itemss in menus)
            {
                <div class="px-5">
                @if (itemss.Id == menuId)
                {
                    
                    <tr>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="px-2 fontContent"><b>@_localizer["lbl_MenuName"]</b></MudText></td>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="fontContent"> @itemss.MenuName</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="px-2 fontContent"><b>@_localizer["lbl_Body"]:</b></MudText></td>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="fontContent">@itemss.Body</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="px-2 fontContent"><b>@_localizer["lbl_ButtonText"]:</b> </MudText></td>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="fontContent">@itemss.ButtonText</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="px-2 fontContent"><b>@_localizer["lbl_Title"]:</b></MudText></td>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="fontContent">@itemss.Title</MudText></td>
                    </tr>
                    <tr>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="px-2 fontContent"><b>@_localizer["lbl_Footer"]:</b> </MudText></td>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="fontContent">@itemss.Footer</MudText></td>
                    </tr>

                    <tr>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="px-2 fontContent"><b>@_localizer["lbl_ItemTitle"]:</b></MudText></td>
                        <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="fontContent">@itemss.ItemTitle</MudText></td>
                    </tr>
                    <tr>
                            @if (itemss.Type == "B")
                            {
                            <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="px-2 fontContent"><b>@_localizer["lbl_MenuType"]:</b></MudText></td>
                            <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="fontContent">@_localizer["lbl_Button"]</MudText></td>
                            }
                            else if (itemss.Type == "M")
                            {
                            <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="px-2 fontContent"><b>@_localizer["lbl_MenuType"]:</b></MudText></td>
                            <td><MudText Color="Color.Secondary" Style="font-size:18px" Class="fontContent">@_localizer["lbl_List"]</MudText></td>
                            }
                    </tr>

                    




                }
                </div>

            }


        </DialogContent>
        <DialogActions>
            <MudButton Class="fontContent" Color="Color.Primary" Variant="Variant.Filled" OnClick="Close">@name_btn</MudButton>
        </DialogActions>
    </MudDialog>
</MudRTLProvider>
@code {
    bool IsRTL;
    string direction;
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }
    [Parameter] public int menuId { set; get; }
    [Parameter] public int botId { set; get; }
    [Parameter] public string name_btn { set; get; }
    [Parameter] public string menuname { set; get; }
    [Parameter] public string str { set; get; }
    [Parameter] public string title { set; get; }
    [Parameter] public List<MenuModel> menus { set; get; }
    string selectedCulture = System.Globalization.CultureInfo.CurrentCulture.TextInfo.CultureName;
    string font_Title;
    string font_Content;
    protected override async Task OnInitializedAsync()
    {
        if (selectedCulture.Contains("ar"))
        {
            font_Content = "font-family:Noto Kufi Arabic;";
            font_Title = "font-family:Noto Kufi Arabic;";
            direction = "rtl";
            IsRTL = true;
        }
        else
        {
            font_Content = "font-family:DROID;";
            font_Title = "font-family:Forte;";
            direction = "ltr";
            IsRTL = false;
        }
        try{
        ResponseModel<MenuModel> response = await _eventsService.GetMenu(botId, str);
        menus = response.Content;
        }
        catch(Exception e){
            Console.WriteLine(e.Message);
        }

    }
    void Close() => MudDialog.Close(DialogResult.Ok(true));

}
