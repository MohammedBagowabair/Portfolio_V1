    public async void submitClient()
    {
        isVisible = true;
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
        Snackbar.Configuration.ShowCloseIcon = false;
        await Task.Delay(2000);
        if (name_btn == _localizer["lbl_BtnSave"])
        {
            client.UserId = int.Parse(UserId);
            ResponsePost<ClientModel> res = await ClientService.Create(client);
            Console.WriteLine($"add code {res.Code}-msg{res.Message}-content{res.Content}");
            try
            {
                if (res.Code == 0)
                {

                    //client.UserId = int.Parse(UserId);
                    ////await ClientService.Update(client);
                    //ResponsePost<ClientModel> res = await ClientService.Create(client);
                    //result = res.Message;
                    //Console.WriteLine(res.Message);
                    //Console.WriteLine($"msg {res.Message} code{res.Code}");
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertSaved"], Severity.Success);
                    StateHasChanged();
                    navigationManager.NavigateTo("/accountPortal");

                }
                else if (res.Code == 3003)
                {
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertSavedandUpdate"], Severity.Success);
                    StateHasChanged();
                    navigationManager.NavigateTo("/accountPortal");
                }
                else if (res.Code == 4004)
                {
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_FSavePackageExpired"], Severity.Error);
                    StateHasChanged();
                    navigationManager.NavigateTo("/accountPortal");
                }
                else{
                isVisible = false;
                Snackbar.Add(_localizer["msg_AlertFSaved"], Severity.Normal);
                Console.WriteLine($"status code:{res.Code},response:{res.Message}");
                StateHasChanged();
                }
                //   else if (res.Code == 3003)
                //{
                //    isVisible = false;
                //    Snackbar.Add(_localizer["msg_DonotHaveSubscription"], Severity.Normal);
                //    StateHasChanged();

                //}
                //else if (res.Code == 3001)
                //{
                //    isVisible = false;
                //    Snackbar.Add(_localizer["msg_DonotHaveSubscription"], Severity.Normal);
                //    StateHasChanged();
                //    navigationManager.NavigateTo("/SeeMoreSubscription");
                //}
            }
            catch(Exception e)
            {

                Console.WriteLine($"msg {e.Message}");
                //Console.WriteLine($"{e.Message}, {e.StackTrace}");
                isVisible = false;
                Snackbar.Add(_localizer["msg_AlertFSaved"], Severity.Normal);
                StateHasChanged();
            }
        }
        else
        {
            var res=await ClientService.Update(client);
            try
            {

                if (res.Code == 0)
                {
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertModified"], Severity.Success);
                    name_btn = _localizer["lbl_BtnSave"];
                    StateHasChanged();
                    navigationManager.NavigateTo("/accountPortal");
                }
                else if(res.Code==3003){
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertModifiedandUpdate"], Severity.Success);
                    name_btn = _localizer["lbl_BtnSave"];
                    StateHasChanged();
                    navigationManager.NavigateTo("/accountPortal");
                }
                else if(res.Code==4004){
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_FModifiedPackageExpired"], Severity.Error);
                    name_btn = _localizer["lbl_BtnSave"];
                    StateHasChanged();
                    navigationManager.NavigateTo("/accountPortal");
                }
                else{
                isVisible = false;
                Snackbar.Add(_localizer["msg_AlertFModified"], Severity.Normal);
                Console.WriteLine($"status code:{res.Code},response:{res.Message}");
                StateHasChanged();
                }
            }
            catch (Exception e)
            {
                Console.WriteLine($"{e.Message}, {e.StackTrace}");
                isVisible = false;
                Snackbar.Add(_localizer["msg_AlertFModified"], Severity.Normal);
                StateHasChanged();
            }
        }

    }
    public void Cancelbtn()
    {
        navigationManager.NavigateTo("/accountPortal");
    }
