@code {
    //[Parameter]
    //public int id { get; set; }
    string font_Title;
    string font_Content;
    string selectedCulture = System.Globalization.CultureInfo.CurrentCulture.TextInfo.CultureName;
    private string result = "";
    [Parameter]
    public string name_btn{ set; get; }
    string title;
    protected string selectValue = string.Empty;
    ClientModel client = new ClientModel();
    ResponseModel<ClientModel> clients;
    private string UserId;



    private bool isVisible;
    protected override async Task OnInitializedAsync()
    {
        if (selectedCulture.Contains("ar"))
        {
            font_Content = "font-family:Noto Kufi Arabic;";
            font_Title = "font-family:Noto Kufi Arabic;";
        }
        else
        {
            font_Content = "font-family:DROID;";
            font_Title = "font-family:Forte;";
        }
        if (name_btn == _localizer["lbl_BtnEdit"])
        {
            title = _localizer["lbl_EditNo"];
            ClientSingle c = Global.Services.GetService<ClientSingle>();
            client = c.client;
        }
        else
        {
            name_btn = _localizer["lbl_BtnSave"];
            title = _localizer["lbl_AddNo"];
        }

        JwtTokenModel token = await _localStorageService.GetItemAsync<JwtTokenModel>("accessToken");
        ClaimsIdentity identity = new ClaimsIdentity(CustomAuthStateProvider.ParseClaimsFromJwt(token.AccessToken), "jwt");
        UserId = identity.FindFirst("UserId").Value;

    }

