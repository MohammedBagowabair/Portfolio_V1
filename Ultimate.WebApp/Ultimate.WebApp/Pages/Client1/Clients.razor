    public async void OpenQRCodeDialog(ClientModel model)
    {
        await getQr(model);
        var options = new DialogOptions()
            {
                Position = DialogPosition.Center,
                MaxWidth = MaxWidth.Large,
                CloseButton = true
            };
        var parameters = new DialogParameters();

        //parameters.Add("QRCodeSRC", model.Qr);

        parameters.Add("QRCodeSRC", model.Qr);
        DialogService.Show<QRCodeDialog>(null, parameters, options);
    }
    async Task DeletedClient()
    {
        try
        {

            result = await clientService.GetClients();
            isSubscribed = await userService.IsUserSubScribed(UserId, "Client");
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
    }
    public void DeleteClient(int userId, int id)
    {
        var parameters = new DialogParameters();
        parameters.Add("title", _localizer["lbl_DeleteClient"].ToString());
        parameters.Add("deleteConfirmation", _localizer["lbl_CofirmDeleteClient"].ToString());
        parameters.Add("buttonText", _localizer["lbl_Deletebtn"].ToString());
        parameters.Add("userId", userId);
        parameters.Add("OnDeleted", EventCallback.Factory.Create(this, DeletedClient));
        parameters.Add("Id", id);
        //parameters.Add("menuName", name);
        //parameters.Add("botId", botId);
        var options = new DialogOptions { FullWidth = true };
        DialogService.Show<ConfirmationDialograzor>(null, parameters, options);
    }

    private void EditClient(int id)
    {
        ClientSingle s = Global.Services.GetService<ClientSingle>();
        s.client = result.Content.Where(x => x.Id == id).FirstOrDefault();

        navigationManager.NavigateTo($"/client/{_localizer["lbl_BtnEdit"]}");
    }
    private async Task EditActivity(ClientModel cln)
    {
        //Console.WriteLine($"activity before updated {cln.Inactive}");
        if (cln.Inactive)
        {
            Console.WriteLine($"activity before updated {cln.Inactive}");
            var parameters = new DialogParameters();
            parameters.Add("title", _localizer["lbl_EditActivity"].ToString());
            parameters.Add("deleteConfirmation", _localizer["lbl_EditActivityConfrim"].ToString());
            parameters.Add("buttonText", _localizer["lbl_Edit"].ToString());
            parameters.Add("OnDeleted", EventCallback.Factory.Create(this, DeletedClient));
            parameters.Add("cln", cln);
            //parameters.Add("OnDeleted", EventCallback.Factory.Create(this, DeletedClient));
            //parameters.Add("Id", id);
            //parameters.Add("menuName", name);
            //parameters.Add("botId", botId);
            var options = new DialogOptions { FullWidth = true };
            DialogService.Show<ConfirmationDialograzor>(null, parameters, options);
            StateHasChanged();
        }
        else
        {

            isVisible = true;
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomStart;
            Snackbar.Configuration.ShowCloseIcon = false;
            await Task.Delay(2000);
            try
            {
                cln.Inactive = !cln.Inactive;
                var re = await clientService.Update(cln);
                //Console.WriteLine($"activity after updated {cln.Inactive}");
                isVisible = false;
                Snackbar.Add(_localizer["msg_AlertModified"], Severity.Success);
                StateHasChanged();
            }
            catch (Exception e)
            {
                cln.Inactive = !cln.Inactive;
                Console.WriteLine($"{e.Message}, {e.StackTrace}");
                isVisible = false;
                Snackbar.Add(_localizer["msg_AlertFModified"], Severity.Normal);
                StateHasChanged();
            }
        }
    }
    private async Task ClientLogout(ClientModel cln)
    {
        isVisible = true;
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomStart;
        Snackbar.Configuration.ShowCloseIcon = false;
        await Task.Delay(2000);
        try
        {
            logOutResulst = await clientService.logOut(cln.Id);
            ResponseAdd<string> responseAdd = await clientService.getQr<string>(cln.Id);
            if (responseAdd.Code == 0)
            {
                if (responseAdd.Content == "Connected")
                {
                    cln.isConnected = true;
                    //StateHasChanged();

                }
                else if (responseAdd.Content == "NotFound")
                {

                    cln.isConnected = false;
                    //StateHasChanged();
                }
                else
                {
                    cln.isConnected = false;
                    cln.Qr = responseAdd.Content;

                }
            }

            else
            {
                cln.isConnected = false;

            }
            isVisible = false;
            Snackbar.Add(_localizer["msg_LogoutSuccess"], Severity.Success);
            StateHasChanged();
            Console.WriteLine($"logout re {logOutResulst.Content}");
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
            isVisible = false;
            Snackbar.Add(_localizer["msg_LogoutFail"], Severity.Normal);
            StateHasChanged();
        }
    }
    private async Task runClient()
    {
        isVisible = true;
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomStart;
        Snackbar.Configuration.ShowCloseIcon = false;
        await Task.Delay(2000);
        try
        {
            var res = await userService.IsUserHaveActiveSubscription(UserId);
            if(res.Content){
                try
                {
                    ResponsGeneric<bool> runResult = await clientService.runClient();

                    isVisible = false;
                    if (runResult.Content == true)
                    {
                        Snackbar.Add(_localizer["msg_RunSuccess"], Severity.Success);
                    }
                    else
                    {
                        Snackbar.Add(_localizer["msg_Fail"], Severity.Success);
                    }


                    Console.WriteLine($"runResult {runResult.Code}-msg {runResult.Message}");
                    StateHasChanged();
                }
                catch (Exception e)
                {
                    Console.WriteLine($"{e.Message}, {e.StackTrace}");
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_RunError"], Severity.Normal);
                    StateHasChanged();
                }
            }
            else
            {
                isVisible = false;
                Snackbar.Add(_localizer["msg_CannotRunBot"], Severity.Normal);
                StateHasChanged();
            }
        }
        catch(Exception e)
        {
            isVisible = false;
            Snackbar.Add(_localizer["msg_CannotRunBot"], Severity.Normal);
            StateHasChanged();
        }
        
    }
    private async Task exitClient()
    {
        isVisible = true;
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomStart;
        Snackbar.Configuration.ShowCloseIcon = false;
        await Task.Delay(2000);
        try
        {
            var exitResult = await clientService.exitClient();
            isVisible = false;
            if (exitResult.Content)
            {
                Snackbar.Add(_localizer["msg_ExitSuccess"], Severity.Success);
            }
            else
            {
                Snackbar.Add(_localizer["msg_Fail"], Severity.Normal);
            }
            StateHasChanged();
            Console.WriteLine($"exitResult {exitResult.Content}");
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
            isVisible = false;
            Snackbar.Add(_localizer["msg_ExitError"], Severity.Normal);
            StateHasChanged();
        }

    }
}
