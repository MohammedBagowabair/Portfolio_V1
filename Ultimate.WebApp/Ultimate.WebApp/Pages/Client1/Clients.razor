    //public bool Inactive;
    protected override async Task OnInitializedAsync()
    {
        if (selectedCulture.Contains("en"))
        {
            font_Content = "font-family:DROID;";
            font_Title = "font-family:Forte;";
        }
        else
        {
            font_Content = "font-family:Noto Kufi Arabic;";
            font_Title = "font-family:Noto Kufi Arabic;";
        }
        try
        {
            JwtTokenModel token = await _localStorageService.GetItemAsync<JwtTokenModel>("accessToken");
            ClaimsIdentity identity = new ClaimsIdentity(CustomAuthStateProvider.ParseClaimsFromJwt(token.AccessToken), "jwt");
            UserId = int.Parse(identity.FindFirst("UserId").Value);
            isSubscribed = await userService.IsUserSubScribed(UserId, "Client");
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
        //result = await clientService.GetClients();
        await GetClient();
        foreach (ClientModel c in result.Content)
        {
            await IsConnected(c.Id);
            c.isConnected = checkConnection;
        }

        //await getQr();
    }
    public async Task GetClient()
    {
        try
        {
            result = await clientService.GetClients();
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
    }
    public async Task navigateToClient(ClientModel client)
    {
        isVisible = true;
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
        Snackbar.Configuration.ShowCloseIcon = false;
        await Task.Delay(2000);
        try
        {
            ResponseModel<BotModel> reslut = await _IBotService.GetBot(client.Id);
            isVisible = false;
            StateHasChanged();
            if (reslut.Content?.Count > 0)
            {
                navigationManager.NavigateTo("/client" + "/" + reslut.Content[0].Id + "/" + client.Id);
            }
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
            isVisible = false;
            Snackbar.Add(_localizer["msg_CheckOnline"], Severity.Normal);
            StateHasChanged();
        }

    }
    public async Task addClient()
    {
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
        Snackbar.Configuration.ShowCloseIcon = false;
        if (isSubscribed.Content == true)
        {
            navigationManager.NavigateTo($"/client/{_localizer["lbl_BtnSave"]}");
        }
        else
        {
            Snackbar.Add(_localizer["msg_DonotHaveSubscription"], Severity.Normal);
            await Task.Delay(1000);
            StateHasChanged();
            navigationManager.NavigateTo("/SeeMoreSubscription");
        }
        //Console.WriteLine($"is subscripded {isSubscribed.Content}");

    }
