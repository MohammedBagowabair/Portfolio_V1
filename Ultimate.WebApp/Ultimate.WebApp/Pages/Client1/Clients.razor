                                                <MudMenu Icon="@Icons.Material.Filled.MoreVert" DisableElevation="true" Size="Size.Medium" IconColor="Color.Secondary" Color="Color.Primary">
                                                    <MudMenuItem Class="fontContent" OnTouch="()=>EditClient(c.Id)" OnClick="()=>EditClient(c.Id)"><span class="fontContent" style="color:#c8cacd">@_localizer["lbl_BtnEdit"]</span></MudMenuItem>
                                                    <MudMenuItem Class="fontContent" OnTouch="()=>DeleteClient(c.UserId,c.Id)" OnClick="()=>DeleteClient(c.UserId,c.Id)"><span class="fontContent" style="color:#c8cacd">@_localizer["lbl_Deletebtn"]</span></MudMenuItem>
