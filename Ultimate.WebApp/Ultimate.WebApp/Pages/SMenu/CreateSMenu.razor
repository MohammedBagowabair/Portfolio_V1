        {
            await form.Validate();
            return;
        }
        isVisible = true;
        try
        {
            var result = new ResponsePost<MenuModel>();
            if (menudetails.ModelState == ModelStates.Update)
            {
                // result =await menuService.UpdateMenu(menudetails);
            }
            else
            {
                result = await menuService.Create(menudetails);
            }
            if (result.Code == 0)
            {

                Snackbar.Add("Seccess", Severity.Success);
                menudetails = new();

                StateHasChanged();
            }
            else
            {
                Snackbar.Add(result.Message, Severity.Error);
            }

        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        isVisible = false;
    }



