@inject IStringLocalizer<Resource> _localizer
@inject IReportCollectionServices reportCollectionServices
@inject IDialogService DialogService
<style>
    .fontTitle {
    @font_Title
    }

    .fontContent {
    @font_Content
    }
</style>
<PageTitle>View Encoding Report</PageTitle>
@*<div style="background-color:#393939">*@
<MudGrid Class="pb-6 px-5">
    @if (!addBtn)
    {
        <MudItem xs="11" sm="11" md="11">
            <MudIconButton Icon="far fa-plus-square" Size="Size.Medium" style="color:#c8cacd" OnClick="NavigateToCreatReport" />
        </MudItem>
        <MudItem xs="11" sm="11" md="11">
            @if (ReportCollections != null)
            {

                <MudTable Items="@ReportCollections.Content"
                  Breakpoint="Breakpoint.Sm" Style="background-color:#393939;">
                    <ColGroup>
                       
                    <col style="width: 40px;  border-bottom:1px solid #4b4848"   />
                    <col style="  border-bottom:1px solid #4b4848"   />
                        
                    </ColGroup>
                    <HeaderContent>
                        <MudTh Style="border-bottom:1px solid #4b4848"></MudTh>
                        <MudTh Style="border-bottom:1px solid #4b4848"><b style=" color:#c8cacd">@_localizer["lbl_Collection"]</b></MudTh>
                        @*<MudTh Style="border-bottom:1px solid #4b4848"><b style=" color:#c8cacd">النموذج</b></MudTh>*@
                        
                        
                    </HeaderContent>
                    @*<GroupHeaderTemplate>

                        <MudTh colspan="6" Style="border-bottom:1px solid #4b4848"><b style=" color:#c8cacd">@($"{context.GroupName}: {context.Key}")</b></MudTh>
                        </GroupHeaderTemplate>*@
                      @*  <RowTemplate>

                        @foreach (EncodingReportModel report in context.reports)
                        {
                            <MudTd Style="color:#c8cacd;border-bottom:1px solid #4b4848" DataLabel="">@report.name</MudTd>
                            <MudTd Style="color:#c8cacd;border-bottom:1px solid #4b4848" DataLabel="">@report.reportTemplate.temp_name</MudTd>
                            <MudTd Style="color:#c8cacd;border-bottom:1px solid #4b4848">
                                <MudLink Underline="Underline.None" Class="px-3" OnClick="()=>EditReport(report)">
                                    <MudIcon Icon="far fa-edit" Size="Size.Small" style="color: #c8cacd;" />
                                </MudLink>
                                <MudLink Underline="Underline.None" Class="text-white" OnClick="()=>DeleteReport(report.id)">
                                    <MudIcon Icon="fas fa-trash-alt" Size="Size.Small" style="color: #c8cacd;"></MudIcon>
                                </MudLink>
                            </MudTd>

                        }

                    </RowTemplate>*@
                    <RowTemplate>
                        <MudTd Style="color:#c8cacd;border-bottom:1px solid #4b4848" DataLabel="">
                            @*<MudButton Variant="Variant.Filled" Size="Size.Small" Class="fontContent" Style="color:#c8cacd" OnClick="()=>showReports(context.id)">عرض التقارير</MudButton>*@
                            @if(context.isShowReports)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Class="fontContent" Style="color:#c8cacd" OnClick="()=>showReports(context.id)"></MudIconButton>
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowRight" Class="fontContent" Style="color:#c8cacd" OnClick="()=>showReports(context.id)"></MudIconButton>
