                            </MudTr>
                    </ChildRowContent>
                </MudTable>
            }
            else
            {
                <MudProgressCircular Color="Color.Primary" Indeterminate="true"  />
            }
        </MudItem>
    }
    else
    {
        <CreateEncodingReport botId="@botId" name_btn="@name_btn" headline="@headline" EncodingReportDto="@reportDto" OnAddOREditReport="ShowAddedOREditedReport" />
    }
</MudGrid>
@*</div>*@
@code {

    ResponseModel<ReportCollectionModel> ReportCollections;

    [Parameter]
    public int botId { set; get; }
    bool addBtn = false;
    string headline;
    string name_btn;
    EncodingReportModel report;
    EncodingReportDto reportDto;
    string selectedCulture = System.Globalization.CultureInfo.CurrentCulture.TextInfo.CultureName;
    string font_Title;
    string font_Content;
    protected override async Task OnInitializedAsync()
    {
        if (selectedCulture.Contains("ar"))
        {
            font_Content = "font-family:Noto Kufi Arabic;";
            font_Title = "font-family:Noto Kufi Arabic;";

        }
        else if (selectedCulture.Contains("en"))
        {
            font_Content = "font-family:DROID;";
            font_Title = "font-family:Forte;";

        }
        try{
            ReportCollections = await reportCollectionServices.GetReportCollectionBybotId(botId);
        }
        catch(Exception e){
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
    }
    private TableGroupDefinition<ReportCollectionModel> _groupDefinition = new()
        {
            GroupName = "المجموعة",
            Indentation = false,
            Expandable = true,
            IsInitiallyExpanded = false,
            Selector = (e) => e.name

        };
    void NavigateToCreatReport()
    {
        reportDto = new EncodingReportDto();
        addBtn = true;
        headline = _localizer["lbl_CreateNewReport"];
        name_btn = _localizer["lbl_BtnSave"];

    }
    private void EditReport(EncodingReportModel Report)
    {
        reportDto.id = Report.id;
        reportDto.name = Report.name;
        reportDto.type = Report.type;
        reportDto.reportCollectionId = Report.reportCollectionId;
        reportDto.reportTemplateId = Report.reportTemplateId;
        reportDto.erpMsgNo = Report.erpMsgNo;
        headline = reportDto.name;
        name_btn = _localizer["lbl_BtnEdit"];
        addBtn = true;
    }
    public async Task ShowAddedOREditedReport()
    {
        try{
            ReportCollections = await reportCollectionServices.GetReportCollectionBybotId(botId);
            addBtn = false;
            headline = _localizer["lbl_CreateNewReport"];
            name_btn = _localizer["lbl_BtnSave"];
        }
        catch(Exception e){
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
        //report = new EncodingReportModel();
    }
    async Task DeletedReport()
    {
        try{
            ReportCollections = await reportCollectionServices.GetReportCollectionBybotId(botId);
        }
        catch(Exception e){
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
    }
    private void DeleteReport(int reportId)
    {

        var parameters = new DialogParameters();
        parameters.Add("title", _localizer["lbl_DeleteEncodingReport"].ToString());
        parameters.Add("deleteConfirmation", _localizer["lbl_ConfirmDeleteReport"].ToString());
        parameters.Add("buttonText", _localizer["lbl_Deletebtn"].ToString());
        parameters.Add("Id", reportId);
        parameters.Add("OnDeleted", EventCallback.Factory.Create(this, (() => DeletedReport())));
        //parameters.Add("menuName", name);
        //parameters.Add("botId", botId);
        var options = new DialogOptions { FullWidth = true };
        DialogService.Show<Ultimate.WebApp.Pages.Menus.ConfirmationDialograzor>(null, parameters, options);
    }
    void showReports(int colId)
    {
        ReportCollectionModel collectionReports = ReportCollections.Content.First(s => s.id == colId);
        collectionReports.isShowReports = !collectionReports.isShowReports;
    }
}
