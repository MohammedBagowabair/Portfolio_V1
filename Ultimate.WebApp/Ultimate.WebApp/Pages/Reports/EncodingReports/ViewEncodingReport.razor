                        </MudTd>
                        <MudTd Style="color:#c8cacd;border-bottom:1px solid #4b4848" DataLabel="@_localizer["lbl_Collection"]">@context.name</MudTd>
                        
                    </RowTemplate>
                    <ChildRowContent>
                        <MudTr Style="background-color:#424242;">
                            <td colspan="6">
                                <MudCard Elevation="0" Style="background-color:#424242;">
