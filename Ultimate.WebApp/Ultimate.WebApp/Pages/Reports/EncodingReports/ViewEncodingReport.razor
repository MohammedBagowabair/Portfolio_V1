                                    {
                                        
                                       
                                        
                                        <MudTable Items="context.reports" Context="report" Breakpoint="Breakpoint.Xs" Elevation="0" Outlined=false Dense=false Style="background-color:#424242;">
                                            <HeaderContent>
                                                <MudTh Class="fontContent" Style="border-bottom:1px solid #4b4848"><b style="color:#c8cacd;">@_localizer["lbl_Report"]</b></MudTh>
