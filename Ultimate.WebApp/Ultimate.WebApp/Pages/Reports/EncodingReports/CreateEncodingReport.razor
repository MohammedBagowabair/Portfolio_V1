@inject IEncodingReportService encodingReportService
@inject ISnackbar Snackbar
@inject IStringLocalizer<Resource> _localizer
@inject IReportCollectionServices reportCollectionServices
@inject IReportTemplateService reportTemplateService
@inject NavigationManager navigationManager
<style>
    .fontTitle {
    @font_Title
    }

    .fontContent {
    @font_Content
    }
</style>
<PageTitle>Create Encoding Report</PageTitle>
@*<div style="background-color:#393939">*@
<EditForm Model="@EncodingReportDto" OnValidSubmit="AddEncodingReport">
    <DataAnnotationsValidator />
    <MudOverlay Visible="isVisible" DarkBackground="true" ZIndex="9999">
        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
    </MudOverlay>
    <MudGrid Spacing="2" Justify="Justify.Center" Class="py-6 px-5">
        @if (ReportCollections != null)
        {
            <MudItem xs="11" sm="8" md="8">
                <MudText Typo="Typo.h5" Color="Color.Secondary" Class="fontContent">@headline</MudText>
        </MudItem>
            <MudItem xs="11" sm="9" md="9">

                <MudSelect @bind-Value="EncodingReportDto.reportCollectionId" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder=@_localizer["lbl_SelectCollection"] For="@(()=>EncodingReportDto.reportCollectionId)" Style="color:#c8cacd" Class="fontContent">
                @foreach (var collection in ReportCollections.Content)
                {
                        <MudSelectItem Value="@(collection.id)"><span style ="color:white" class="fontContent">@collection?.name</span></MudSelectItem>
                    }
                </MudSelect>

            </MudItem>
            <MudItem xs="11" sm="4" md="4">
                <MudTextField @bind-Value="EncodingReportDto.name" Variant="Variant.Outlined" Placeholder=@_localizer["lbl_EnterTheName"] Margin="Margin.Dense" Style="color:#c8cacd" For="@(()=>EncodingReportDto.name)" Class="fontContent"></MudTextField>
            </MudItem>
            <MudItem xs="11" sm="2" md="2">
                <MudTextField @bind-Value="EncodingReportDto.erpMsgNo" Variant="Variant.Outlined" Placeholder=@_localizer["lbl_MsgNo"] Margin="Margin.Dense" Style="color:#c8cacd" For="@(()=>EncodingReportDto.erpMsgNo)" Class="fontContent" InputType="InputType.Number"></MudTextField>

            </MudItem>
            <MudItem xs="11" sm="3" md="3">
                @if (ReportTemplates != null)
                {
                    <MudSelect @bind-Value="EncodingReportDto.reportTemplateId" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder=@_localizer["lbl_SelectReport"] For="@(()=>EncodingReportDto.reportTemplateId)" Style="color:#c8cacd" Class="fontContent">
                        @foreach (var template in ReportTemplates.Content)
                        {
                            <MudSelectItem Value="@(template.id)" ><span style ="color:white" class="fontContent">@template?.temp_name</span></MudSelectItem>
                        }
                    </MudSelect>
                }
            </MudItem>
           
            <MudItem xs="11" sm="11" md="11">
                <MudText Class="fontContent" Color="Color.Error">@validatedCollection</MudText>

            </MudItem>
            <MudItem xs="10" sm="9" md="8">
                <MudGrid Spacing="1" Justify="Justify.Center" Class="pt-6">
                    <MudItem xs="6" sm="4" md="3" >
                        <MudButton DisableElevation="true" Variant="Variant.Filled" Color="Color.Primary" FullWidth ButtonType="ButtonType.Submit" Class="py-2 fontContent" OnClick="AddEncodingReport">@name_btn</MudButton>
                </MudItem>
                    <MudItem xs="6" sm="4" md="3">
                        <MudButton DisableElevation="true" Variant="Variant.Filled" Color="Color.Secondary" FullWidth Class="py-2 fontContent" OnClick="CancelBtn">@_localizer["lbl_Cancelbtn"]</MudButton>
                </MudItem>
            </MudGrid>
        </MudItem>
        }
    </MudGrid>
</EditForm>
@*</div>*@
@code {
    [Parameter]
    public EncodingReportDto EncodingReportDto { set; get; }
    //public EncodingReportModel EncodingReport { set; get; }
   
    ResponseModel<ReportCollectionModel> ReportCollections;
    ResponseModel<ReportTemplateModel> ReportTemplates;
    [Parameter]
    public int botId { set; get; }
    [Parameter]
    public string headline { set; get; }
    [Parameter]
    public string name_btn { set; get; }
    private bool isVisible;
    string validatedCollection;
    [Parameter]
    public EventCallback OnAddOREditReport { set; get; }
    string selectedCulture = System.Globalization.CultureInfo.CurrentCulture.TextInfo.CultureName;
    string font_Title;
    string font_Content;
    protected override async Task OnInitializedAsync()
    {
        if (selectedCulture.Contains("ar"))
        {
            font_Content = "font-family:Noto Kufi Arabic;";
            font_Title = "font-family:Noto Kufi Arabic;";

        }
        else if (selectedCulture.Contains("en"))
        {
            font_Content = "font-family:DROID;";
            font_Title = "font-family:Forte;";

        }
        ReportCollections = await reportCollectionServices.GetReportCollectionBybotId(botId);
        ReportTemplates = await reportTemplateService.GetReportTemplates();
    }
    private async Task AddEncodingReport()
    {
        if (EncodingReportDto.reportCollectionId == 0 || EncodingReportDto.reportTemplateId == 0)
        {
            validatedCollection = _localizer["msg_SelectCollectionOrTemplate"];
        }
        else
        {
            validatedCollection = string.Empty;
            isVisible = true;
            Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
            Snackbar.Configuration.ShowCloseIcon = false;
            await Task.Delay(1000);
            if (name_btn == _localizer["lbl_BtnSave"])
            {
                try
                {
                    ResponsePost<EncodingReportDto> res = await encodingReportService.Create(EncodingReportDto);
                    //Console.WriteLine("11111111name: " + EncodingReport.name);
                    //Console.WriteLine("11111111Collection: " + EncodingReport.reportCollectionId);
                    //Console.WriteLine("11111111Template: " + EncodingReport.reportTemplateId);
                    //isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertSaved"], Severity.Success);
                    EncodingReportDto = new EncodingReportDto();
                    await OnAddOREditReport.InvokeAsync();

                    StateHasChanged();
                }

                catch (Exception e)
                {
                    Console.WriteLine($"{e.Message}, {e.StackTrace}");
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertFSaved"], Severity.Normal);
                    StateHasChanged();
                }
            }
            else if (name_btn == _localizer["lbl_BtnEdit"])
            {
                try
                {
                    
                    //EncodingReportDto.id = EncodingReport.id;
                    //Console.WriteLine("eeeeeeeeeee: " + EncodingReportDto.id);
                    //EncodingReportDto.name = EncodingReport.name;
                    //EncodingReportDto.type = EncodingReport.type;
                    //EncodingReportDto.reportCollectionId = EncodingReport.reportCollectionId;
                    //EncodingReportDto.reportTemplateId = EncodingReport.reportTemplateId;
                    //EncodingReportDto.erpMsgNo = EncodingReport.erpMsgNo;
                    ResponseModel res = await encodingReportService.UpdateEncodingReport(EncodingReportDto);
                    //Console.WriteLine("1111111122name: " + EncodingReport.name);
                    //Console.WriteLine("1111111122Collection: " + EncodingReport.reportCollectionId);
                    //Console.WriteLine("1111111122Template: " + EncodingReport.reportTemplateId);
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertModified"], Severity.Success);
                    EncodingReportDto = new EncodingReportDto();
                    await OnAddOREditReport.InvokeAsync();

                    //headline = _localizer["lbl_CreateNewReport"];
                    //name_btn = _localizer["lbl_BtnSave"];
                    StateHasChanged();


                }
                catch (Exception e)
                {
                    Console.WriteLine($"{e.Message}, {e.StackTrace}");
                    isVisible = false;
                    Snackbar.Add(_localizer["msg_AlertFModified"], Severity.Normal);
                    StateHasChanged();
                }
            }
        }
    }
    async Task CancelBtn()
    {
        await OnAddOREditReport.InvokeAsync();
        //navigationManager.NavigateTo("");
    }
}
