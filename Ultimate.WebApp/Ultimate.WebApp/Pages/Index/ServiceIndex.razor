                    <MudCardMedia Image="img/Responsive-amico.png" alt="Card image cap" />
                <MudCardContent>
                        <MudText Class="fontTitle" Typo="Typo.h6" Style="margin-bottom:1px; color:white"><span style="color:#c8cacd">@_localizer["lbl_F"]</span>@_localizer["lbl_flexibleservices"]</MudText>
