                    <br />
            </MudCardContent>
        </MudCard>
        </MudItem>
                <MudItem xs="11" sm="6" md="3" Class="d-flex align-self-stretch">
                <MudCard Style="background-color:#4aa47e;width: 18rem; margin:7px">

                    <MudCardMedia Image="img/Business ethics-pana.png" alt="Card image cap" />
                    <MudCardContent>
                        <MudText Class="fontTitle" Typo="Typo.h6" Style="margin-bottom:1px; color:white"><span style="color:#c8cacd">@_localizer["lbl_B"]</span>@_localizer["lbl_balance_services"]</MudText>
                        <MudText Class="fontContent" Style="color:white">@_localizer["lbl_OurServices71"]</MudText>
                    <br />
            </MudCardContent>
        </MudCard>
        </MudItem>
    </MudGrid>

    </MudContainer>


