                    <MudCardMedia Image="img/Speed test-rafiki.png" alt="Card image cap" />
                <MudCardContent>
                        <MudText Class="fontTitle" Typo="Typo.h6" Style="margin-bottom:1px; color:white"><span style="color:#c8cacd">@_localizer["lbl_S"]</span>@_localizer["lbl_speedservices"]</MudText>
