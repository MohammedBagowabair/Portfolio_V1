                                          </MudTable>
                                    
                                      </div>
                             @*   @foreach(var menu in template.sMenu){
                                    <div class="d-flex flex-row pb-3 justify-space-between">

                                        <MudText Color="Color.Secondary" Class="fontContent" style="font-size:16px">@menu.MenuName</MudText>
