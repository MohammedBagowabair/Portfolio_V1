                                        }
                                            else if(menu.displayTemplateDetails=="block"){
                                                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowUp" Size="Size.Small" Color="Color.Secondary" Class="mx-2" OnClick="@(()=>hideDetails(menu.MenuName,template.Id))" />

                                            }
                                       
                               </div>
                                    </div>*@
                                 @*   @foreach (var item in menu.Items ){

                                  
                                    <div style=" display: @menu.displayTemplateDetails;">
                                            <MudText Color="Color.Secondary" Class="fontContent pb-3" Style="font-size:14px">@item.ActionValue</MudText>
