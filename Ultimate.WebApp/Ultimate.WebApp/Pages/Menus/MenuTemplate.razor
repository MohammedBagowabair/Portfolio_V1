@code {
    ResponseModel<TemplateModel> templates;
    [Parameter]
    public int botId { set; get; }
    [Parameter]
    public EventCallback OnAddOREditMenu { set; get; }
    public List<TextModel> text_Q { get; set; }
    private bool isVisible;
    protected override async Task OnInitializedAsync(){
        try{
            templates = await menuService.GetTemplate();
        }
        catch(Exception e){
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
    }
    public void showDetails( int tempId)
    {

        //MenuModel tempMenu = templates.Content.First(t => t.Id == tempId).sMenu.First(m => m.MenuName == menuName);
        TemplateModel temp = templates.Content.First(t => t.Id == tempId);
        
        temp.displayTemplateDetails = "block";
        Console.WriteLine($"menu {temp.name}");
        

        foreach (var menu in temp.sMenu){
            foreach (var item in menu.Items){
                GetActionValue(item);
            }
            
        }
        //Console.WriteLine($"temp {temp.name}");
        StateHasChanged();
    }
    public void hideDetails( int tempId){

        TemplateModel temp = templates.Content.First(t => t.Id == tempId);
        temp.displayTemplateDetails = "none";

        StateHasChanged();
    }
    public async Task GetActionValue(MenuItemModel item)
    {
        Console.WriteLine($"value {item.ActionValue} action {item.Action}");
        //separate from here to method and send action as a parameter because will use this method in update as well
        //to perevent duplicated code twice
        MenuItemModel menuItem = item;

        if (item.Action == "S^T^Q^1000")
        {
            item.ActionValue = _localizer["lbl_Send"] + " " + _localizer["lbl_balanceText"];
        }
        else
        {
            string actionValue = item.Action.Substring(0, 6); 
            int eventMenuId;
            int eventTextId;
            int eventReportG;
            ResponseModel<MenuModel> MenusForEvent;
            ResponsGeneric<ReportCollectionModel> reportGForEvent;
      
            Console.WriteLine($" sub action {actionValue}");
            if (actionValue == "N^M^S^")
            {
                eventMenuId = Convert.ToInt32(item.Action.Substring(6));
                MenusForEvent = await menuService.GetMenuById(eventMenuId);
                item.ActionValue = _localizer["lbl_MoveToMenus"] + " " + MenusForEvent.Content[0].MenuName;
            }
            else if (actionValue == "N^M^Q^")
            {
                eventMenuId = Convert.ToInt32(item.Action.Substring(6));
                MenusForEvent = await menuService.GetMenuById(eventMenuId);
                item.ActionValue = _localizer["lbl_MoveToMenus"] + " " + MenusForEvent.Content[0].MenuName;
            }
            else if (actionValue == "S^M^Q^")
            {
                item.ActionValue = _localizer["lbl_Send"] +" "+ _localizer["lbl_AccountStatement"];
            }
            else if (actionValue == "S^T^S^")
            {
                item.ActionValue = _localizer["lbl_SendTextt"] +" "+ item.Action.ToString().Substring(6);
            }
            else if (actionValue == "S^T^Q^")
            {
                eventTextId= Convert.ToInt32(item.Action.Substring(6));
    @foreach (var items_txtQ in text_Q)
                {
                    if (items_txtQ.id == eventTextId)
                    {
                        item.ActionValue = _localizer["lbl_SendQText"] + " " + items_txtQ.name;
                    }
                }
                
            }
            else if (actionValue == "S^M^S^")
            {
                //Console.WriteLine($"aaa{action}");
                item.ActionValue = _localizer["lbl_Send"]+" " + _localizer["lbl_Photo"];
            }
            else if (actionValue == "N^M^R^")
            {
                eventReportG = Convert.ToInt32(item.Action.Substring(6));
                reportGForEvent = await reportCollectionServices.GetReportCollectionById(eventReportG);
                item.ActionValue = _localizer["lbl_MoveToReportColl"] + " " + reportGForEvent.Content.name;
            }
            else
            {

            }

        }
        StateHasChanged();

    }
    public async Task defualtMenu(int temId)
    {
        Console.WriteLine($" defualt menu {botId} - tempid {temId}");
        isVisible = true;
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomLeft;
        Snackbar.Configuration.ShowCloseIcon = false;
        await Task.Delay(1000);
        try
        {
            ResponseModel<MenuModel> res = await menuService.SetDefaultMenu(botId, temId);
            Console.WriteLine($" defualt menu {botId}");
            if(res.Code==0)
            {
                isVisible = false;
                Snackbar.Add(_localizer["msg_AlertSaved"], Severity.Success);
                await OnAddOREditMenu.InvokeAsync();

                StateHasChanged();
            }
            else if(res.Code==3003){
                isVisible = false;
                Snackbar.Add(_localizer["msg_AlertSavedandUpdate"], Severity.Success);
                await OnAddOREditMenu.InvokeAsync();
                StateHasChanged();
            }
            else if (res.Code == 3001)
            {

                isVisible = false;
                Snackbar.Add(_localizer["msg_DonotHaveSubscription"], Severity.Normal);
                //await OnAddOREditMenu.InvokeAsync();
                StateHasChanged();
                navigationManager.NavigateTo("/SeeMoreSubscription");

            }
            else if (res.Code == 4004)
            {
                isVisible = false;
                Snackbar.Add(_localizer["msg_FSavePackageExpired"], Severity.Success);
                
                await OnAddOREditMenu.InvokeAsync();

                StateHasChanged();


            }
            else
            {
                isVisible = false;
                Snackbar.Add(_localizer["msg_AlertFSaved"], Severity.Normal);
                Console.WriteLine($"status code:{res.Code},response:{res.Message}");
                StateHasChanged();
            }
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
            isVisible = false;
            Snackbar.Add(_localizer["msg_AlertFSaved"], Severity.Normal);
            StateHasChanged();
        }

    }
    
}
