@page "/indexmenu"
@inject IMenuService menuService
@inject IDialogService DialogService
@inject IStringLocalizer<Resource> _localizer
@inject ISnackbar Snackbar
@inject IUserService userService
@inject ILocalStorageService _localStorageService
@inject NavigationManager navigationManager
@using System.Security.Claims
<style>
    .mud-typography-body1 {
        font-size: var(--mud-typography-body1-size);
    @font_Content;
        font-weight: var(--mud-typography-body1-weight);
        line-height: var(--mud-typography-body1-lineheight);
        letter-spacing: var(--mud-typography-body1-letterspacing);
        text-transform: var(--mud-typography-body1-text-transform);
    }

    .fontTitle {
    @font_Title
    }

    .fontContent {
    @font_Content
    }

    /*.only .mud-menu *{
            color:#4aa47e;

        }*/
</style>
<MudGrid Spacing="0">
    <MudOverlay Visible="isVisible" DarkBackground="true" ZIndex="9999">
        <MudProgressCircular Color="Color.Secondary" Indeterminate="true" />
    </MudOverlay>
    <MudItem xs="11" sm="11" md="3">

        @*<MudPaper Elevation="0" Class="d-flex flex-column overflow-scroll ">*@

        @*            <MudItem xs="11" sm="11" md="11">*@

        <MudButtonGroup Color="Color.Primary" Variant="Variant.Filled" Class=" d-flex mt-5 mx-5" Size="Size.Large" DisableElevation=true>
            <MudButton Class="fontContent" OnClick="@(()=>getMenuByType("s"))"><span style="color:white" class="fontContent"> @_localizer["lbl_Menus"] </span></MudButton>
            <MudButton Class="fontContent" OnClick="@(()=>getMenuByType("Q"))"><span style="color:white" class="fontContent">@_localizer["lbl_EncodingMenus"]</span></MudButton>
            @*<MudButton StartIcon="@Icons.Material.Filled.Add" OnClick="btnClicked">إضافة قائمة</MudButton>*@

        </MudButtonGroup>

        @*  <MudButtonGroup  Color="Color.Primary" Variant="Variant.Filled" Class=" d-flex mt-5 mx-5" Size="Size.Large" DisableElevation=true>

        <MudButton Class="fontContent"  >@_buttonText</MudButton>

        <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown" Class="fontContent">
        <MudMenuItem OnClick="@(() => SetButtonText(0,"s"))"><span style="color:white" class="fontContent"> @_localizer["lbl_Menus"] </span></MudMenuItem>
        <MudMenuItem OnClick="@(() => SetButtonText(1,"Q"))"><span style="color:white" class="fontContent">@_localizer["lbl_EncodingMenus"]</span></MudMenuItem>
        <MudMenuItem OnClick="@(() => SetButtonText(2,"s"))"><span style="color:white" class="fontContent">قوائم جاهزة</span></MudMenuItem>

        </MudMenu>
        <MudIconButton Icon="@Icons.Material.Filled.Add" OnClick="btnClicked" />
        </MudButtonGroup>*@

        @*<MudButton DisableElevation="true" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Add" Color="Color.Primary" OnClick="btnClicked" Class="mx-4">@_localizer["lbl_Add"]</MudButton>*@

        <MudList Clickable="true" @bind-SelectedItem="selectedItem" @bind-SelectedValue="selectedValue" Color="Color.Primary">
            <MudContainer>
                @*<div class="d-flex flex-row justify-space-between">*@
                <MudGrid Spacing="0">
                    <MudItem xs="10" sm="10" md="10">
                        <MudText Class="fontContent" Color="Color.Secondary" Typo="Typo.h6">@typeHeadline</MudText>
                    </MudItem>
                    <MudItem xs="2" sm="2" md="2">
                        @*<div class="only">*@
                        <MudMenu Icon="@Icons.Material.Filled.Add" Class="fontContent" Color="Color.Primary">
                            <MudMenuItem OnTouch="@(()=>btnClicked("menu"))" OnClick="@(()=>btnClicked("menu"))"><span style="color:white" class="fontContent">@_localizer["lbl_OneMenu"]</span></MudMenuItem>
                            <MudMenuItem OnTouch="@(()=>btnClicked("template"))" OnClick="@(()=>btnClicked("template"))"><span style="color:white" class="fontContent">@_localizer["lbl_MenuTemplates"]</span></MudMenuItem>
                            @*<MudIconButton Color="Color.Primary" Icon="@Icons.Material.Filled.Add" OnClick="btnClicked" />*@
                        </MudMenu>
                        @*</div>*@
                    </MudItem>
                </MudGrid>
                @*</div>*@
            </MudContainer>





            @if (result != null)
            {


                @foreach (MenuModel menu in result.Content)
                {


                    <MudContainer>
                        <MudGrid Spacing="0" Justify="Justify.FlexStart">
                            <MudItem xs="2" sm="1" md="2">
                                <MudAvatar Color="Color.Primary" Size="Size.Medium">
                                    @if (menu.Type == "M")
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.FormatListBulleted" Size="Size.Small" Style="color:white" />
                                    }
                                    else if (menu.Type == "B")
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.RadioButtonChecked" Size="Size.Small" Style="color:white" />

                                    }
                                </MudAvatar>
                            </MudItem>
                            <MudItem xs="8" sm="9" md="8">
                                <MudListItem Class="fontContent mud-typography-body1" Value="@(result.Content.IndexOf(menu))" OnClick="()=>editMenu(menu.Id)" Text="@menu.MenuName">
                                    @*<span class="fontContent">@menu.MenuName</span>*@
                                </MudListItem>
                            </MudItem>
                            <MudItem xs="2" sm="2" md="2">
                                <MudIconButton Icon="@Icons.Material.Outlined.Delete" OnClick="()=>deleteMenu(menu.Id,menu.structureType)" Color="Color.Secondary" />

                            </MudItem>
                        </MudGrid>



                    </MudContainer>




                }
            }
            else
            {

            }
        </MudList>


        @*</MudItem>*@

        @*</MudPaper>*@


    </MudItem>
    <MudItem xs="11" sm="11" md="8">

        <MudPaper Elevation="0" Class="py-6 mx-5" Style="background-color:#393939;">


            @*<h6> @(selectedItem?.Text ?? "select item ")</h6>*@
            @if (@selectedItem?.Text != null && clickedAdd_btn == false && menuInfo != null && typeAdd != "menu" && typeAdd != "template")
            {
                @*<h4>@selectedItem.Text</h4>*@

                @*if (_buttonText == @_localizer["lbl_Menus"])*@
                if (typeHeadline == @_localizer["lbl_Menus"])
                {
                    <CreateMenu botId="@botId" headline=@headline menudetails="@menuInfo" name_btn="@name_btn" OnAddOREditMenu="@(()=>ShowAddedOREditedMenu("s"))" Type="s"></CreateMenu>

                }
                @*else if (_buttonText == @_localizer["lbl_EncodingMenus"])*@
                else if (typeHeadline == @_localizer["lbl_EncodingMenus"])
                {
                    <CreateMenu botId="@botId" headline=@headline menudetails="@menuInfo" name_btn="@name_btn" OnAddOREditMenu="@(()=>ShowAddedOREditedMenu("Q"))" Type="Q"></CreateMenu>

                }

                @*<CreateMenu botId="@botId" headline=@headline menudetails="@menuInfo" name_btn=@name_btn OnAddOREditMenu="ShowAddedOREditedMenu"></CreateMenu>*@





            }
            else if (clickedAdd_btn == true && typeAdd == "menu")
            {
                @*if (_buttonText == @_localizer["lbl_Menus"])*@
                if (typeHeadline == @_localizer["lbl_Menus"])
                {
                    <CreateMenu botId="@botId" headline=@headline menudetails="@menuInfo" name_btn="@name_btn" OnAddOREditMenu="@(()=>ShowAddedOREditedMenu("s"))" Type="s"></CreateMenu>
                    @*clickedAdd_btn = false;*@
                }
                @*else if (_buttonText == @_localizer["lbl_EncodingMenus"])*@
                else if (typeHeadline == @_localizer["lbl_EncodingMenus"])
                {
                    <CreateMenu botId="@botId" headline=@headline menudetails="@menuInfo" name_btn="@name_btn" OnAddOREditMenu="@(()=>ShowAddedOREditedMenu("Q"))" Type="Q"></CreateMenu>
                    @*clickedAdd_btn = false;*@
                }

            }
            else if (clickedAdd_btn == true && typeAdd == "template")
            {


                <MenuTemplate botId="@botId" OnAddOREditMenu="@(()=>ShowAddedOREditedMenu(typeHeadline))" />




                @*<MudProgressCircular Color="Color.Primary" Indeterminate="true" />*@
            }

        </MudPaper>

    </MudItem>


</MudGrid>

@code {
    string font_Title;
    string font_Content;
    string selectedCulture = System.Globalization.CultureInfo.CurrentCulture.TextInfo.CultureName;
    [Parameter]
    public int botId { set; get; }
    MudListItem selectedItem;
    object selectedValue;
    bool clickedAdd_btn = false;
    string headline;
    string typeHeadline;
    string name_btn;
    string icon;
    string typeAdd;
    int UserId;
    //private string _buttonText;
    ResponsGeneric<bool> isSubscribed;

    //List<string> menus = new List<string> { "قائمة1", "قائمة2", "قائمة3", "قائمة4", "قائمة5", "قائمة6" };
    ResponseModel<MenuModel> result;

    MenuModel menuInfo;
    bool isVisible;
    protected override async Task OnInitializedAsync()
    {
        if (selectedCulture.Contains("ar"))
        {
            font_Content = "font-family:Noto Kufi Arabic;";
            font_Title = "font-family:Noto Kufi Arabic;";
        }
        else
        {
            font_Content = "font-family:DROID;";
            font_Title = "font-family:Forte;";
        }
        typeHeadline = _localizer["lbl_Menus"];
        //_buttonText = _localizer["lbl_Menus"];
        JwtTokenModel token = await _localStorageService.GetItemAsync<JwtTokenModel>("accessToken");
        ClaimsIdentity identity = new ClaimsIdentity(CustomAuthStateProvider.ParseClaimsFromJwt(token.AccessToken), "jwt");
         UserId = int.Parse(identity.FindFirst("UserId").Value);
        isSubscribed = await userService.IsUserSubScribed(UserId, "Menu");
        try
        {
            result = await menuService.GetMenuBybotId(botId, "s");
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
    }
    private async Task getMenuByType(string type)
    {
        result = null;
        clickedAdd_btn = false;
        //typeHeadline = null;
        selectedItem = null;
        selectedValue = null;
        if (type == "s")
        {
            typeHeadline = _localizer["lbl_Menus"];

        }
        else if (type == "Q")
        {
            typeHeadline = _localizer["lbl_EncodingMenus"];

        }
        try
        {
            result = await menuService.GetMenuBybotId(botId, type);
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }


        StateHasChanged();
    }
    public async Task btnClicked(string addtype)
    {
        Snackbar.Configuration.PositionClass = Defaults.Classes.Position.BottomRight;
        Snackbar.Configuration.ShowCloseIcon = false;
        if (isSubscribed.Content == true)
        {
            clickedAdd_btn = true;

            if (addtype == "menu")
            {
                typeAdd = "menu";
                menuInfo = new MenuModel();
                //if (typeHeadline == "القوائم")
                //{
                //    menuInfo.structureType = "s";
                //}
                //else if (typeHeadline == "ترميز القوائم")
                //{
                //    menuInfo.structureType = "Q";
                //}

                selectedValue = null;
                selectedItem = null;

                headline = _localizer["lbl_CreateMenu"];
                name_btn = _localizer["lbl_BtnSave"];
            }
            else if (addtype == "template")
            {
                typeAdd = "template";
            }

        }
        else
        {
            Snackbar.Add(_localizer["msg_DonotHaveSubscription"], Severity.Normal);
            await Task.Delay(1000);

            navigationManager.NavigateTo("/SeeMoreSubscription");
        }
        StateHasChanged();


    }
    async Task ShowAddedOREditedMenu(string type)
    {
        try
        {
            if (type == _localizer["lbl_Menus"]){
                //Console.WriteLine($"hhhh{typeHeadline}*{type}");
                result = await menuService.GetMenuBybotId(botId, "s");
            }
            else if(type==_localizer["lbl_EncodingMenus"]){
               //Console.WriteLine($"hhhh{typeHeadline}*{type}");
                result = await menuService.GetMenuBybotId(botId, "Q");
            }
            else{
                //Console.WriteLine($"hhhh{typeHeadline}*{type}");
                result = await menuService.GetMenuBybotId(botId, type);
            }
            isSubscribed = await userService.IsUserSubScribed(UserId, "Menu");
            headline = _localizer["lbl_CreateMenu"];
            name_btn = _localizer["lbl_BtnSave"];

            menuInfo = new MenuModel();
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }


    }
    async Task DeletedMenu(string type)
    {
        try
        {

            result = await menuService.GetMenuBybotId(botId, type);
            isSubscribed = await userService.IsUserSubScribed(UserId, "Menu");
        }
        catch (Exception e)
        {
            Console.WriteLine($"{e.Message}, {e.StackTrace}");
        }
    }

    public async Task editMenu(int? menuId)
    {
       
        StateHasChanged();

    }
    async void deleteMenu(int? menuId, string type)
    {

        var parameters = new DialogParameters();
        parameters.Add("title", _localizer["lbl_DeleteMenu"].ToString());
        parameters.Add("deleteConfirmation", _localizer["lbl_CofirmDelete"].ToString());
        parameters.Add("buttonText", _localizer["lbl_Deletebtn"].ToString());
        parameters.Add("menuId", menuId);
        parameters.Add("OnDeleted", EventCallback.Factory.Create(this, (() => DeletedMenu(type))));
        //parameters.Add("menuName", name);
        //parameters.Add("botId", botId);
        var options = new DialogOptions { FullWidth = true };
        DialogService.Show<ConfirmationDialograzor>(null, parameters, options);



    }
