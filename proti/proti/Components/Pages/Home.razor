@page "/"

@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Medium" Class="my-8">
    <MudPaper Elevation="10" Class="pa-4">
        <MudText Typo="Typo.h4" Class="mb-4">Propofol Information</MudText>

        <MudText Typo="Typo.body1" Class="mb-4">
            Propofol is a short-acting medication that results in a decreased level of consciousness and lack of memory for events.
            It is used for the induction and maintenance of general anesthesia, sedation for mechanically ventilated adults, and procedural sedation.
        </MudText>

        <MudText Typo="Typo.h6" Class="mt-4 mb-2">Uses</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            - Induction and maintenance of general anesthesia<br />
            - Sedation in intensive care units<br />
            - Procedural sedation
        </MudText>

        <MudText Typo="Typo.h6" Class="mt-4 mb-2">Side Effects</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            - Hypotension<br />
            - Bradycardia<br />
            - Respiratory depression<br />
            - Pain at the injection site
        </MudText>

        <MudText Typo="Typo.h6" Class="mt-4 mb-2">Precautions</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            - Should be administered by trained personnel<br />
            - Monitor for respiratory and cardiovascular depression<br />
            - Use with caution in patients with egg or soybean allergies
        </MudText>

        <MudText Typo="Typo.h6" Class="mt-4 mb-2">Dosage</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            - Induction: 1.5 to 2.5 mg/kg IV<br />
            - Maintenance: 100 to 200 mcg/kg/min IV
        </MudText>

        <MudText Typo="Typo.h6" Class="mt-4 mb-2">References</MudText>
        <MudText Typo="Typo.body1" Class="mb-4">
            - American Society of Anesthesiologists<br />
            - FDA Prescribing Information
        </MudText>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" Href="https://www.fda.gov" Target="_blank">
            Learn More
        </MudButton>
    </MudPaper>
</MudContainer>