<script>
    // Character counter functionality
    const messageField = document.getElementById('message');
    const charCounter = document.querySelector('.chars-remaining');

    messageField.addEventListener('input', function () {
        const remaining = 500 - this.value.length;
        charCounter.textContent = `${remaining} characters remaining`;
        charCounter.style.color = remaining < 50 ? '#f59e0b' : '#64748b';
    });

    // Form submission animation
    const form = document.getElementById('aiContactForm');
    const submitBtn = document.querySelector('.btn-ai-submit');
    const processingIndicator = document.querySelector('.ai-processing');

    form.addEventListener('submit', function (e) {
        e.preventDefault();
        submitBtn.disabled = true;
        processingIndicator.style.opacity = '1';

        // Simulate AI processing
        setTimeout(() => {
            processingIndicator.style.opacity = '0';
            submitBtn.disabled = false;
            alert('Your message has been analyzed and routed to our AI support team!');
            form.reset();
        }, 2000);
    });
</script>
<style>
:root {
    --primary: #2563eb;
    --primary-dark: #1e40af;
    --secondary: #f0f4f8;
    --accent: #f59e0b;
    --accent-light: #fbbf24;
    --white: #ffffff;
    --dark: #1e293b;
    --gray: #64748b;
    --gradient: linear-gradient(135deg, #2563eb 0%, #1e40af 100%);
    --gradient-accent: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
    --neon-glow: 0 0 10px rgba(59, 130, 246, 0.5);
    --neon-glow-accent: 0 0 10px rgba(245, 158, 11, 0.5);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', sans-serif;
    background-color: var(--white);
    color: var(--dark);
    overflow-x: hidden;
}

.ai-platform {
    padding: 100px 20px;
    background-color: var(--secondary);
    position: relative;
    overflow: hidden;
}

.container {
    max-width: 1200px;
    margin: auto;
    position: relative;
    z-index: 2;
}

.section-header {
    text-align: center;
    margin-bottom: 80px;
}

.ai-badge {
    display: inline-block;
    background: var(--gradient-accent);
    color: var(--white);
    padding: 8px 20px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 20px;
    letter-spacing: 1px;
    box-shadow: var(--neon-glow-accent);
}

.section-header h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 3rem;
    color: var(--dark);
    position: relative;
    display: inline-block;
    line-height: 1.2;
    margin-bottom: 20px;
}

.section-header h2 .ai-highlight {
    position: relative;
    display: inline;
    background: linear-gradient(120deg, var(--accent) 0%, var(--accent-light) 100%);
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
}

.section-header p {
    font-size: 1.2rem;
    color: var(--gray);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.7;
}

.ai-features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
}

.ai-card {
    background: var(--white);
    border-radius: 16px;
    padding: 40px 30px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.03);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.1);
    position: relative;
    overflow: hidden;
}

.ai-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 5px;
    background: var(--gradient);
    transition: all 0.4s ease;
}

.ai-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(37, 99, 235, 0.1), var(--neon-glow);
}

.ai-card:hover::before {
    height: 10px;
    background: var(--gradient-accent);
}

.ai-icon {
    width: 80px;
    height: 80px;
    background: var(--gradient);
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 25px;
    box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3), var(--neon-glow);
    transition: all 0.4s ease;
}

.ai-card:hover .ai-icon {
    transform: rotate(10deg) scale(1.1);
    background: var(--gradient-accent);
    box-shadow: 0 15px 25px rgba(245, 158, 11, 0.3), var(--neon-glow-accent);
}

