    position: absolute;
    bottom: -8px;
    left: 0;
    width: 50px;
    height: 3px;
    background: var(--primary);
    transition: all 0.4s ease;
}

.ai-card:hover h3::after {
    width: 70px;
    background: var(--accent);
}

.ai-card p {
    color: var(--gray);
    margin-bottom: 20px;
    line-height: 1.7;
}

.ai-feature-list {
    margin-bottom: 25px;
}

.ai-feature-item {
    display: flex;
    align-items: flex-start;
    margin-bottom: 12px;
    transition: all 0.3s ease;
}

.ai-feature-item:hover {
