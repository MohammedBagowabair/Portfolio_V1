    box-shadow: 0 8px 20px rgba(37, 211, 102, 0.4);
}

.whatsapp-badge i {
    margin-right: 8px;
}

.ai-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
}

.ai-particle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.1;
    filter: blur(20px);
    animation: float 15s infinite ease-in-out;
}

.particle-1 {
    width: 300px;
    height: 300px;
    top: -100px;
    right: -100px;
    background: var(--primary);
    animation-delay: 0s;
}

.particle-2 {
    width: 200px;
    height: 200px;
    bottom: -50px;
    left: -50px;
    background: var(--accent);
    animation-delay: 2s;
}

.particle-3 {
    width: 150px;
    height: 150px;
    top: 40%;
    left: 20%;
    background: var(--primary-dark);
    animation-delay: 4s;
}

.ai-circuit {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 1;
    opacity: 0.03;
    pointer-events: none;
}

@@keyframes float {
    0%, 100% {
    transform: translateY(0) rotate(0deg);
    }
    50% {
    transform: translateY(-20px) rotate(5deg);
    }
}

@@media (max-width: 768px) {
    .section-header h2 {
    font-size: 2.2rem;
    }
      
    .section-header p {
    font-size: 1.1rem;
    }
      
