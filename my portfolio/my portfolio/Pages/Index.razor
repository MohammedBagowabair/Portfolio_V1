<style>
    /* Animation for the heading */
    @@keyframes fadeInDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Animation for the paragraph */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Apply animations to the heading and paragraph */
    .animated-heading {
        animation: fadeInDown 1s ease-out forwards;
    }

    .animated-paragraph {
        animation: fadeInUp 1s ease-out 0.5s forwards; /* Delay of 0.5s */
        opacity: 0; /* Start invisible */
    }
</style>

