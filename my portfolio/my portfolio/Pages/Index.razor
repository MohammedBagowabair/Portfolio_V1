<style>

    #skills {
        padding: 40px 20px;
        background-color: #ffffff;
        text-align: center;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    #skills h2 {
        font-size: 2.8rem;
        color: #2c3e50;
        margin-bottom: 15px;
        font-weight: 700;
        position: relative;
        display: inline-block;
        text-align: center;
        letter-spacing: 1px;
        padding-top:23px;
    }

    #skills h2 .highlight {
        color: #6C63FF;
        position: relative;
    }

    #skills h2::after {
        content: "";
        display: block;
        width: 60px;
        height: 3px;
        background-color: #6C63FF;
        margin: 10px auto 0;
        border-radius: 2px;
    }

    #skills p {
        font-size: 1.15rem;
        color: #555555;
        max-width: 800px;
        margin: 20px auto 40px;
        line-height: 1.7;
        text-align: center;
        padding: 0 1rem;
    }

    .skills-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 25px;
        justify-items: center;
        max-width: 1200px;
        margin: 0 auto;
    }

    .skills-section {
        background-color: #f9f9ff;
        padding: 25px 20px;
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(108, 99, 255, 0.15);
        text-align: left;
        width: 100%;
        transition: transform 0.35s ease, box-shadow 0.35s ease;
        border: 1px solid #e0e0e0;
    }

    .skills-section:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 30px rgba(108, 99, 255, 0.3);
    }

    .skills-header {
        display: flex;
        align-items: center;
        margin-bottom: 18px;
    }

    .skills-icon {
        font-size: 1.7rem;
        margin-right: 14px;
        color: #6C63FF;
    }

    .skills-section h3 {
        font-size: 1.5rem;
        margin-bottom: 18px;
        color: #2c3e50;
        font-weight: 600;
    }

    .skill {
        background-color: #ffffff;
        padding: 12px 14px;
        border-radius: 7px;
        font-size: 1.05rem;
        color: #333333;
        margin-bottom: 12px;
        border: 1.5px solid #e0e0e0;
        cursor: default;
        user-select: none;
        transition: background-color 0.3s ease, color 0.3s ease, transform 0.3s ease, border-color 0.3s ease;
    }

    .skill:hover {
        background-color: #6C63FF;
        color: white;
        transform: translateX(6px);
        border-color: #6C63FF;
    }

    /* Responsive tweaks */
    @@media (max-width: 992px) {
