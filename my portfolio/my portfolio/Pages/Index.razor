    /* Global Styles */
    body {
        font-family: 'Segoe UI', sans-serif;
        background-color: #fff;
        color: #333;
        margin: 0;
        padding: 0;
    }

    /* Section Styling */
    .section {
        padding: 4rem 2rem;
        background-color: #f9f9f9;
        border-top: 1px solid #e0e0e0;
        border-bottom: 1px solid #e0e0e0;
    }

    /* Header & Titles */
    h2 {
        font-size: 2rem;
        margin-bottom: 1.5rem;
        font-family: 'Segoe UI', sans-serif;
        color: #333;
        text-align: center;
    }

    p {
        font-family: 'Segoe UI', sans-serif;
        color: #555;
        font-size: 1rem;
        text-align: center;
        line-height: 1.6;
    }

    /* About Me Section Styling */
    .about-content {
        max-width: 800px;
        margin: 0 auto;
        text-align: center;
    }

    /* Profile Section Styling */
    .profile-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        margin: 0 auto;
    }

    /* Profile Image Styling */
    .profile-image {
        border-radius: 50%;
        width: 150px;
        height: 150px;
        object-fit: cover;
        border: 4px solid var(--rz-primary-color);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .profile-image:hover {
            transform: scale(1.1);
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        }

    /* Name Styling with Gradient Text */
    .name-text {
        font-size: 2rem;
        font-weight: bold;
        margin-top: 1rem;
        background: linear-gradient(45deg, #3498db, #9b59b6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: gradient-shift 3s infinite alternate;
    }

    /* Title Styling */
    .title-text {
        font-size: 1.5rem;
        color: #7f8c8d;
        margin-top: 0.5rem;
        font-weight: 500;
        animation: fade-in 2s ease-in-out infinite alternate;
    }



    /* Grid Layouts for Skills, Projects, and Services */
    .skills-grid, .projects-grid, .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
    }

    .skill, .project, .service {
        background-color: #f9f9f9;
        padding: 1rem;
        border-radius: 4px;
        text-align: center;
        font-family: 'Segoe UI', sans-serif;
    }

    /* Button Style */
    .btn-primary {
        background-color: #007bff;
        border: none;
        padding: 0.5rem 1.5rem;
        color: white;
        cursor: pointer;
        border-radius: 4px;
        font-weight: 500;
        transition: background-color 0.3s;
    }

        .btn-primary:hover {
            background-color: #0056b3;
        }

    /* Form Styling */
    form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 400px;
        margin: 0 auto;
    }

    input, textarea {
        padding: 0.5rem;
        border: 1px solid #e0e0e0;
        border-radius: 4px;
    }

    textarea {
        resize: vertical;
    }

    /* Floating Button Style */
    .floating-button {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background-color: #007bff;
        color: white;
        border-radius: 50%;
        width: 60px;
        height: 60px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
        font-size: 24px;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .floating-button:hover {
            background-color: #0056b3;
        }

</style>

